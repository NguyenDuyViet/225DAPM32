@model IEnumerable<_225DAPM32.Models.Order>
@{
    ViewData["Title"] = "Lịch sử giao hàng";
}

<h2 class="mb-4">Lịch sử giao hàng</h2>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-muted py-5">Chưa có lịch sử giao hàng.</div>
    </div>
}
else
{
    <div class="vstack gap-3">
        @foreach (var order in Model)
        {
            var canceled = order.Status == "cancelled" || order.Status == "canceled";
            var hasDriverReview = !canceled && order.DriverRating.HasValue && order.DriverRating.Value > 0;
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <h5 class="mb-0 fw-bold">@order.OrderCode</h5>
                                <span class="badge @(canceled ? "bg-danger" : "bg-success")">
                                    @(canceled ? "Đã hủy" : "Hoàn thành")
                                </span>
                            </div>
                            <div class="text-muted small">
                                <i class="fas fa-store me-1"></i>@order.RestaurantName
                                <span class="mx-2">|</span>
                                @order.UpdatedAt?.ToString("HH:mm dd/MM/yyyy")
                            </div>
                        </div>
                        <div class="text-lg-end">
                            <div class="text-muted small">Phí giao hàng</div>
                            <div class="fw-bold text-success fs-5">@order.ShippingFee.ToString("N0") VND</div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-lg-7">
                            <div class="bg-light rounded-3 p-3 h-100">
                                <h6 class="fw-bold mb-3">Thông tin đơn đã giao</h6>
                                <p class="mb-1"><i class="fas fa-user me-2 text-muted"></i>@(order.CustomerName ?? "Khách hàng") <span class="text-muted">@order.CustomerPhone</span></p>
                                <p class="mb-3"><i class="fas fa-location-dot me-2 text-muted"></i>@order.DeliveryAddress</p>
                                <div class="border-top pt-2">
                                    @foreach (var item in order.Items)
                                    {
                                        <div class="d-flex justify-content-between small py-1">
                                            <span>@item.Quantity x @item.FoodName</span>
                                            <span class="text-muted">@item.TotalPrice.ToString("N0") VND</span>
                                        </div>
                                    }
                                </div>
                                <div class="d-flex justify-content-between border-top mt-2 pt-2 fw-semibold">
                                    <span>Tổng đơn hàng</span>
                                    <span>@order.FinalTotal.ToString("N0") VND</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-5">
                            <div class="border rounded-3 p-3 h-100">
                                <h6 class="fw-bold mb-3"><i class="fas fa-star text-warning me-2"></i>Đánh giá về shipper</h6>
                                @if (hasDriverReview)
                                {
                                    <div class="d-flex align-items-center mb-2">
                                        <span class="fs-4 fw-bold text-warning">@order.DriverRating?.ToString("0.0")</span>
                                        <span class="ms-2 text-warning"><i class="fas fa-star"></i> / 5</span>
                                    </div>
                                    <p class="mb-2">@(string.IsNullOrWhiteSpace(order.CommentForShipper) ? "Khách hàng không để lại nhận xét." : order.CommentForShipper)</p>
                                    @if (order.ReviewedAt.HasValue)
                                    {
                                        <small class="text-muted">Đánh giá lúc @order.ReviewedAt.Value.ToString("HH:mm dd/MM/yyyy")</small>
                                    }
                                }
                                else
                                {
                                    <p class="text-muted mb-0">Khách hàng chưa đánh giá shipper cho đơn hàng này.</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
