@model _225DAPM32.Areas.Shipper.Models.ShipperDashboardViewModel
@{
    ViewData["Title"] = "Dashboard Shipper";
}

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card border-0 shadow-sm p-3"><small class="text-muted">Đơn đang xử lý</small><h3 class="mb-0 text-warning">@Model.ActiveDeliveries</h3></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm p-3"><small class="text-muted">Đơn hoàn thành</small><h3 class="mb-0 text-success">@Model.CompletedDeliveries</h3></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm p-3"><small class="text-muted">Thu nhập hôm nay</small><h3 class="mb-0 text-info">@Model.TodayEarnings.ToString("N0") đ</h3></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm p-3"><small class="text-muted">Đánh giá</small><h3 class="mb-0 text-primary">@Model.Rating.ToString("0.0")</h3></div></div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0">Đơn đang được phân công</h5>
        <a asp-area="Shipper" asp-controller="Shipper" asp-action="Orders" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
    </div>
    <div class="card-body p-0">
        @if (!Model.CurrentOrders.Any())
        {
            <p class="text-center text-muted py-5 mb-0">Hiện chưa có đơn giao được phân công.</p>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var order in Model.CurrentOrders)
                {
                    <div class="list-group-item p-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="mb-1">@order.OrderCode - @order.RestaurantName</h6>
                                <div class="small text-muted"><i class="fas fa-location-dot me-1"></i>@order.DeliveryAddress</div>
                                <div class="small text-muted mt-1">@order.CustomerName - @order.CustomerPhone</div>
                            </div>
                            <span class="badge bg-@order.StatusColor">@order.StatusText</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
