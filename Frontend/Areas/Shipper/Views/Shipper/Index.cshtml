@{
    ViewData["Title"] = "Dashboard Shipper";
}

<!-- Shipper Header -->
<div class="admin-header bg-dark text-white py-4 mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 mb-0">
                    <i class="fas fa-motorcycle me-3"></i>Dashboard Shipper
                </h1>
                <p class="mb-0 opacity-75">Quản lý đơn hàng giao hàng</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="d-flex align-items-center justify-content-end">
                    <div class="me-3 text-end">
                        <small class="opacity-75">Hôm nay</small>
                        <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="status-indicator me-3">
                        <i class="fas fa-circle text-success me-1"></i>
                        <span>Online</span>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user me-2"></i>Shipper
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Shipper")"><i class="fas fa-user me-2"></i>Thông tin cá nhân</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Earnings", "Shipper")"><i class="fas fa-wallet me-2"></i>Thu nhập</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Settings", "Shipper")"><i class="fas fa-cog me-2"></i>Cài đặt</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-2">
            <div class="shipper-sidebar">
                <nav class="nav flex-column">
                    <a class="nav-link active" href="@Url.Action("Index", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a class="nav-link" href="@Url.Action("Orders", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-clipboard-list me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("History", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-history me-2"></i>Lịch sử
                    </a>
                    <a class="nav-link" href="@Url.Action("Earnings", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-wallet me-2"></i>Thu nhập
                    </a>
                    <a class="nav-link" href="@Url.Action("Profile", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-user me-2"></i>Profile
                    </a>
                    <a class="nav-link" href="@Url.Action("Settings", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                </nav>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-10">
            <!-- Stats Cards -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-warning">
                                    <i class="fas fa-route"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">8</h3>
                                    <small class="text-muted">Đơn đang giao</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-success">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">24</h3>
                                    <small class="text-muted">Đơn hoàn thành</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-info">
                                    <i class="fas fa-dollar-sign"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">450K</h3>
                                    <small class="text-muted">Thu nhập hôm nay</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-primary">
                                    <i class="fas fa-star"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">4.8</h3>
                                    <small class="text-muted">Đánh giá</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Current Orders -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Đơn hàng đang giao</h5>
                            <a href="@Url.Action("Orders", "Shipper")" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
                        </div>
                        <div class="card-body p-0">
                            <div class="row g-0">
                                <div class="col-md-6">
                                    <div class="order-item p-3 border-end">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div>
                                                <h6 class="mb-1">#12345</h6>
                                                <small class="text-muted">Phở 24 Restaurant</small>
                                            </div>
                                            <span class="badge bg-warning">Đang giao</span>
                                        </div>
                                        <div class="order-details mb-3">
                                            <p class="mb-1"><i class="fas fa-map-marker-alt me-2"></i>123 Đường ABC, Q.1, TP.HCM</p>
                                            <p class="mb-1"><i class="fas fa-user me-2"></i>Nguyễn Văn A - 0123 456 789</p>
                                            <p class="mb-1"><i class="fas fa-shopping-bag me-2"></i>2 món • 185,000 VND</p>
                                            <p class="mb-1"><i class="fas fa-clock me-2"></i>Dự kiến: 11:30 AM</p>
                                        </div>
                                        <div class="order-actions">
                                            <button class="btn btn-success btn-sm me-2" onclick="markDelivered(12345)">
                                                <i class="fas fa-check me-1"></i>Đã giao
                                            </button>
                                            <button class="btn btn-outline-primary btn-sm" onclick="callCustomer(12345)">
                                                <i class="fas fa-phone me-1"></i>Gọi khách
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="order-item p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div>
                                                <h6 class="mb-1">#12346</h6>
                                                <small class="text-muted">Pizza Hut</small>
                                            </div>
                                            <span class="badge bg-warning">Đang giao</span>
                                        </div>
                                        <div class="order-details mb-3">
                                            <p class="mb-1"><i class="fas fa-map-marker-alt me-2"></i>456 Đường XYZ, Q.2, TP.HCM</p>
                                            <p class="mb-1"><i class="fas fa-user me-2"></i>Trần Thị B - 0987 654 321</p>
                                            <p class="mb-1"><i class="fas fa-shopping-bag me-2"></i>1 món • 150,000 VND</p>
                                            <p class="mb-1"><i class="fas fa-clock me-2"></i>Dự kiến: 12:00 PM</p>
                                        </div>
                                        <div class="order-actions">
                                            <button class="btn btn-success btn-sm me-2" onclick="markDelivered(12346)">
                                                <i class="fas fa-check me-1"></i>Đã giao
                                            </button>
                                            <button class="btn btn-outline-primary btn-sm" onclick="callCustomer(12346)">
                                                <i class="fas fa-phone me-1"></i>Gọi khách
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Map and Route -->
            <div class="row mb-4">
                <div class="col-md-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Bản đồ giao hàng</h5>
                        </div>
                        <div class="card-body">
                            <div id="map" style="height: 400px; background: #f8f9fa; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <div class="text-center">
                                    <i class="fas fa-map-marked-alt fa-3x text-muted mb-3"></i>
                                    <p class="text-muted">Bản đồ sẽ hiển thị ở đây</p>
                                    <small class="text-muted">Tích hợp Google Maps API</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Tuyến đường tiếp theo</h5>
                        </div>
                        <div class="card-body">
                            <div class="route-list">
                                <div class="route-item mb-3 p-3 bg-light rounded">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="route-number bg-warning text-white rounded-circle me-3">
                                            1
                                        </div>
                                        <div>
                                            <h6 class="mb-0">#12345</h6>
                                            <small class="text-muted">2.3 km • 15 phút</small>
                                        </div>
                                    </div>
                                    <p class="mb-0 small">123 Đường ABC, Q.1, TP.HCM</p>
                                </div>
                                <div class="route-item mb-3 p-3 bg-light rounded">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="route-number bg-warning text-white rounded-circle me-3">
                                            2
                                        </div>
                                        <div>
                                            <h6 class="mb-0">#12346</h6>
                                            <small class="text-muted">3.1 km • 20 phút</small>
                                        </div>
                                    </div>
                                    <p class="mb-0 small">456 Đường XYZ, Q.2, TP.HCM</p>
                                </div>
                                <div class="route-item p-3 bg-light rounded">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="route-number bg-secondary text-white rounded-circle me-3">
                                            3
                                        </div>
                                        <div>
                                            <h6 class="mb-0">#12347</h6>
                                            <small class="text-muted">4.5 km • 25 phút</small>
                                        </div>
                                    </div>
                                    <p class="mb-0 small">789 Đường DEF, Q.3, TP.HCM</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Earnings Summary -->
            <div class="row">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Tóm tắt thu nhập hôm nay</h5>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-md-3">
                                    <div class="earnings-item">
                                        <h4 class="text-success">450K</h4>
                                        <small class="text-muted">Tổng thu nhập</small>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="earnings-item">
                                        <h4 class="text-primary">24</h4>
                                        <small class="text-muted">Đơn hoàn thành</small>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="earnings-item">
                                        <h4 class="text-info">18.8K</h4>
                                        <small class="text-muted">Thu nhập trung bình/đơn</small>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="earnings-item">
                                        <h4 class="text-warning">8.2</h4>
                                        <small class="text-muted">Giờ làm việc</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.shipper-header {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}

.shipper-sidebar {
    background: #f8f9fa;
    border-radius: 10px;
    padding: 20px 0;
    min-height: calc(100vh - 200px);
}

.shipper-sidebar .nav-link {
    color: #495057;
    padding: 12px 20px;
    margin: 5px 15px;
    border-radius: 8px;
    transition: all 0.3s ease;
}

.shipper-sidebar .nav-link:hover {
    background: #e9ecef;
    color: #212529;
}

.shipper-sidebar .nav-link.active {
    background: #ffc107;
    color: #212529;
}

.status-indicator {
    display: flex;
    align-items: center;
    font-weight: 500;
}

.stats-card {
    border-radius: 10px;
    transition: transform 0.3s ease;
}

.stats-card:hover {
    transform: translateY(-2px);
}

.stats-icon {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
}

.order-item {
    border-bottom: 1px solid #e9ecef;
}

.order-item:last-child {
    border-bottom: none;
}

.order-details p {
    margin-bottom: 8px;
    font-size: 14px;
}

.route-number {
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 14px;
}

.earnings-item {
    padding: 20px 0;
    border-right: 1px solid #e9ecef;
}

.earnings-item:last-child {
    border-right: none;
}
</style>

<script>
function markDelivered(orderId) {
    if (confirm('Xác nhận đã giao thành công đơn hàng #' + orderId + '?')) {
        // Giả lập cập nhật trạng thái
        alert('Đã cập nhật trạng thái đơn hàng #' + orderId);
        location.reload();
    }
}

function callCustomer(orderId) {
    // Giả lập gọi điện
    alert('Đang gọi khách hàng của đơn hàng #' + orderId);
}
</script>