@model _225DAPM32.Areas.Shipper.Models.ShipperEarningsViewModel
@{
    ViewData["Title"] = "Thu nhập";
}

<h2 class="mb-4">Thu nhập</h2>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 h-100">
            <h5 class="text-muted">Thu nhập tuần</h5>
            <p class="display-6 fw-bold text-primary mb-0">@Model.WeekTotal.ToString("N0") VND</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 h-100">
            <h5 class="text-muted">Thu nhập hôm nay</h5>
            <p class="display-6 fw-bold text-success mb-0">@Model.TodayTotal.ToString("N0") VND</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 h-100">
            <h5 class="text-muted">Đơn hoàn thành</h5>
            <p class="display-6 fw-bold text-info mb-0">@Model.CompletedOrders</p>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5 class="card-title">Tổng quan</h5>
        <p class="card-text mb-0">Bạn đang có <strong class="text-warning">@Model.PendingOrders</strong> đơn đang thực hiện. Giữ trạng thái giao hàng ổn định để tăng thu nhập nhé.</p>
    </div>
</div>
