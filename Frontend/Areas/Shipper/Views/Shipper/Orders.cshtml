@model IEnumerable<_225DAPM32.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng cần giao";
}

<!-- Header -->
<div class="admin-header bg-dark text-white py-4 mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 mb-0">
                    <i class="fas fa-clipboard-list me-3"></i>Đơn hàng cần giao
                </h1>
                <p class="mb-0 opacity-75">Danh sách đơn đang chờ xử lý</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">

        <!-- Sidebar -->
        <div class="col-md-2">
            <div class="shipper-sidebar">
                <nav class="nav flex-column">
                    <a class="nav-link" href="@Url.Action("Index", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a class="nav-link active" href="@Url.Action("Orders", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-clipboard-list me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("History", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-history me-2"></i>Lịch sử
                    </a>
                    <a class="nav-link" href="@Url.Action("Earnings", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-wallet me-2"></i>Thu nhập
                    </a>
                    <a class="nav-link" href="@Url.Action("Profile", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-user me-2"></i>Profile
                    </a>
                    <a class="nav-link" href="@Url.Action("Settings", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                </nav>
            </div>
        </div>

        <!-- Main content -->
        <div class="col-md-10">
            @if (TempData["Success"] is string success)
            {
                <div class="alert alert-success">@success</div>
            }
            @if (TempData["Error"] is string error)
            {
                <div class="alert alert-danger">@error</div>
            }

            <!-- Filter -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <input type="text" class="form-control w-25" placeholder="Tìm mã đơn...">
                <input type="date" class="form-control w-auto">
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Trạng thái</th>
                                    <th>Tổng tiền</th>
                                    <th>Shipper</th>
                                    <th>Dự kiến giao</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-5">Chưa có đơn đang giao được phân công.</td>
                                    </tr>
                                }
                                @foreach (var order in Model)
                                {
                                    var statusClass = order.Status switch
                                    {
                                        "pending" => "bg-warning text-dark",
                                        "confirmed" => "bg-primary",
                                        "delivering" => "bg-info",
                                        "completed" => "bg-success",
                                        _ => "bg-secondary"
                                    };
                                    var statusText = order.Status == "delivering" ? "Đang giao" : order.Status;

                                    <tr>
                                        <td><strong>@order.OrderCode</strong></td>

                                        <td>
                                            <span class="badge @statusClass">
                                                @statusText
                                            </span>
                                        </td>

                                        <td class="fw-bold text-primary">
                                            @order.FinalTotal.ToString("N0") VND
                                        </td>

                                        <td>
                                            <i class="fas fa-user me-1"></i>
                                            @order.DriverName
                                        </td>

                                        <td>
                                            @order.EstimatedDelivery?.ToString("HH:mm dd/MM")
                                        </td>

                                        <td>
                                            @if (order.Status == "delivering")
                                            {
                                                <form asp-area="Shipper" asp-controller="Shipper" asp-action="MarkCompleted" method="post" class="d-inline">
                                                    <input type="hidden" name="orderId" value="@order.IdOrder" />
                                                    <button type="submit" class="btn btn-success btn-sm">
                                                        <i class="fas fa-check me-1"></i>Đã giao
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<style>
.shipper-sidebar {
    background: #f8f9fa;
    border-radius: 10px;
    padding: 20px 0;
    min-height: calc(100vh - 200px);
}

.shipper-sidebar .nav-link {
    color: #495057;
    padding: 12px 20px;
    margin: 5px 15px;
    border-radius: 8px;
    transition: 0.3s;
}

.shipper-sidebar .nav-link:hover {
    background: #e9ecef;
}

.shipper-sidebar .nav-link.active {
    background: #ffc107;
    color: #212529;
}

.table tbody tr:hover {
    background-color: #f8f9fa;
}
</style>
