@model IEnumerable<_225DAPM32.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng cần giao";
}

<!-- Header -->
<div class="admin-header bg-dark text-white py-4 mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 mb-0">
                    <i class="fas fa-clipboard-list me-3"></i>Đơn hàng cần giao
                </h1>
                <p class="mb-0 opacity-75">Danh sách đơn đang chờ xử lý</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">

        <!-- Sidebar -->
        <div class="col-md-2">
            <div class="shipper-sidebar">
                <nav class="nav flex-column">
                    <a class="nav-link" href="@Url.Action("Index", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a class="nav-link active" href="@Url.Action("Orders", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-clipboard-list me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("History", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-history me-2"></i>Lịch sử
                    </a>
                    <a class="nav-link" href="@Url.Action("Earnings", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-wallet me-2"></i>Thu nhập
                    </a>
                    <a class="nav-link" href="@Url.Action("Profile", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-user me-2"></i>Profile
                    </a>
                    <a class="nav-link" href="@Url.Action("Settings", "Shipper", new { area = "Shipper" })">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                </nav>
            </div>
        </div>

        <!-- Main content -->
        <div class="col-md-10">

            <!-- Filter -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <input type="text" class="form-control w-25" placeholder="🔍 Tìm mã đơn...">
                <input type="date" class="form-control w-auto">
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Trạng thái</th>
                                    <th>Tổng tiền</th>
                                    <th>Shipper</th>
                                    <th>Dự kiến giao</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model)
                                {
                                    var statusClass = order.Status switch
                                    {
                                        "Pending" => "bg-warning",
                                        "Delivering" => "bg-info",
                                        "Completed" => "bg-success",
                                        _ => "bg-secondary"
                                    };

                                    <tr>
                                        <td><strong>#@order.IdOrder</strong></td>

                                        <td>
                                            <span class="badge @statusClass">
                                                @order.Status
                                            </span>
                                        </td>

                                        <td class="fw-bold text-primary">
                                            @order.FinalTotal.ToString("N0") VND
                                        </td>

                                        <td>
                                            <i class="fas fa-user me-1"></i>
                                            @order.DriverName
                                        </td>

                                        <td>
                                            @order.EstimatedDelivery?.ToString("HH:mm dd/MM")
                                        </td>

                                        <td>
                                            <button class="btn btn-success btn-sm me-1"
                                                    onclick="markDelivering(@order.IdOrder)">
                                                <i class="fas fa-truck"></i>
                                            </button>

                                            <button class="btn btn-primary btn-sm me-1"
                                                    onclick="callCustomer(@order.IdOrder)">
                                                <i class="fas fa-phone"></i>
                                            </button>

                                            <button class="btn btn-danger btn-sm"
                                                    onclick="cancelOrder(@order.IdOrder)">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<style>
.shipper-sidebar {
    background: #f8f9fa;
    border-radius: 10px;
    padding: 20px 0;
    min-height: calc(100vh - 200px);
}

.shipper-sidebar .nav-link {
    color: #495057;
    padding: 12px 20px;
    margin: 5px 15px;
    border-radius: 8px;
    transition: 0.3s;
}

.shipper-sidebar .nav-link:hover {
    background: #e9ecef;
}

.shipper-sidebar .nav-link.active {
    background: #ffc107;
    color: #212529;
}

.table tbody tr:hover {
    background-color: #f8f9fa;
}
</style>

<script>
function markDelivering(orderId) {
    if (confirm("Bắt đầu giao đơn #" + orderId + "?")) {
        alert("Đã chuyển sang trạng thái đang giao!");
        location.reload();
    }
}

function callCustomer(orderId) {
    alert("Đang gọi khách đơn #" + orderId);
}

function cancelOrder(orderId) {
    if (confirm("Hủy đơn #" + orderId + "?")) {
        alert("Đã hủy đơn!");
        location.reload();
    }
}
</script>