@model _225DAPM32.Areas.Shipper.Models.ShipperProfileViewModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<h2 class="mb-4">Thông tin cá nhân</h2>

<div class="card border-0 shadow-sm p-4">
    <div class="row align-items-center">
        <div class="col-md-3 text-center">
            <div class="avatar-circle mx-auto">
                <span>@(string.IsNullOrEmpty(Model.Name) ? "S" : Model.Name.Substring(0, 1).ToUpper())</span>
            </div>
        </div>

        <div class="col-md-9">
            <h3 class="mb-3">@Model.Name</h3>
            <div class="row">
                <div class="col-md-6">
                    <p><i class="fas fa-phone me-2"></i><strong>Điện thoại:</strong> @Model.Phone</p>
                    <p><i class="fas fa-envelope me-2"></i><strong>Email:</strong> @Model.Email</p>
                    <p><i class="fas fa-circle me-2 text-success"></i><strong>Trạng thái:</strong> @Model.Status</p>
                </div>
                <div class="col-md-6">
                    <p><i class="fas fa-star text-warning me-2"></i><strong>Đánh giá:</strong> @Model.Rating</p>
                    <p><i class="fas fa-check-circle text-success me-2"></i><strong>Đơn hoàn thành:</strong> @Model.CompletedDeliveries</p>
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-primary me-2"><i class="fas fa-edit me-1"></i>Cập nhật hồ sơ</button>
                <button class="btn btn-outline-secondary"><i class="fas fa-key me-1"></i>Đổi mật khẩu</button>
            </div>
        </div>
    </div>
</div>

<style>
    .avatar-circle {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ffc107, #fd7e14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        color: white;
        font-weight: bold;
    }
</style>
