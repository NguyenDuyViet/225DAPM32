<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Setup dates defaults for create promo modal
        const now = new Date();
        const startString = now.toISOString().slice(0, 16);
        const inOneMonth = new Date(now.setMonth(now.getMonth() + 1));
        const endString = inOneMonth.toISOString().slice(0, 16);
        
        document.getElementById("createPromoStart").value = startString;
        document.getElementById("createPromoEnd").value = endString;

        // FOODS EDIT MODAL DATA BINDING
        const editFoodButtons = document.querySelectorAll(".edit-food-btn");
        editFoodButtons.forEach(btn => {
            btn.addEventListener("click", function() {
                const id = this.getAttribute("data-id");
                const name = this.getAttribute("data-name");
                const category = this.getAttribute("data-category");
                const desc = this.getAttribute("data-description");
                const price = this.getAttribute("data-price");
                const discount = this.getAttribute("data-discount");
                const image = this.getAttribute("data-image");
                const video = this.getAttribute("data-video");
                const preptime = this.getAttribute("data-preptime");
                const dailyquantity = this.getAttribute("data-dailyquantity");

                document.getElementById("editFoodId").value = id;
                document.getElementById("editFoodName").value = name;
                document.getElementById("editFoodCategory").value = category;
                document.getElementById("editFoodDescription").value = desc;
                document.getElementById("editFoodPrice").value = price;
                document.getElementById("editFoodDiscount").value = discount;
                document.getElementById("editFoodImage").value = image;
                document.getElementById("editFoodVideo").value = video;
                document.getElementById("editFoodPrepTime").value = preptime;
                document.getElementById("editFoodDailyQuantity").value = dailyquantity;
            });
        });

        // FOODS DELETE MODAL DATA BINDING
        const deleteFoodButtons = document.querySelectorAll(".delete-food-btn");
        deleteFoodButtons.forEach(btn => {
            btn.addEventListener("click", function() {
                const id = this.getAttribute("data-id");
                const name = this.getAttribute("data-name");

                document.getElementById("deleteFoodId").value = id;
                document.getElementById("deleteFoodNameDisplay").textContent = name;
            });
        });

        // PROMOTION EDIT MODAL DATA BINDING
        const editPromoButtons = document.querySelectorAll(".edit-promo-btn");
        editPromoButtons.forEach(btn => {
            btn.addEventListener("click", function() {
                const id = this.getAttribute("data-id");
                const type = this.getAttribute("data-type");
                const val = this.getAttribute("data-value");
                const minval = this.getAttribute("data-minval");
                const maxdisc = this.getAttribute("data-maxdisc");
                const limit = this.getAttribute("data-limit");
                const used = this.getAttribute("data-used");
                const start = this.getAttribute("data-start");
                const end = this.getAttribute("data-end");

                document.getElementById("editPromoId").value = id;
                document.getElementById("editPromoType").value = type;
                document.getElementById("editPromoValue").value = val;
                document.getElementById("editPromoMinVal").value = minval;
                document.getElementById("editPromoMaxDisc").value = maxdisc;
                document.getElementById("editPromoLimit").value = limit;
                document.getElementById("editPromoUsedCount").value = used;
                document.getElementById("editPromoStart").value = start;
                document.getElementById("editPromoEnd").value = end;
            });
        });

        // PROMOTION DELETE MODAL DATA BINDING
        const deletePromoButtons = document.querySelectorAll(".delete-promo-btn");
        deletePromoButtons.forEach(btn => {
            btn.addEventListener("click", function() {
                const id = this.getAttribute("data-id");
                document.getElementById("deletePromoId").value = id;
            });
        });
    });
</script>

