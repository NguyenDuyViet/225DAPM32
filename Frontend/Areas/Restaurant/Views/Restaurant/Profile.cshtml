@model _225DAPM32.Models.Restaurant
@{
    ViewData["Title"] = "Quản lý Nhà hàng";
    var foods = ViewBag.Foods as List<_225DAPM32.Models.Food> ?? new List<_225DAPM32.Models.Food>();
    var categories = ViewBag.Categories as List<_225DAPM32.Models.Category> ?? new List<_225DAPM32.Models.Category>();
    var promotions = ViewBag.Promotions as List<_225DAPM32.Models.Promotion> ?? new List<_225DAPM32.Models.Promotion>();
    var reviews = ViewBag.Reviews as List<_225DAPM32.Areas.Restaurant.RestaurantController.ReviewViewModel> ?? new List<_225DAPM32.Areas.Restaurant.RestaurantController.ReviewViewModel>();
}

<div class="admin-header bg-dark text-white py-4 mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 mb-0">
                    <i class="fas fa-store me-3 text-success"></i>Dashboard Nhà hàng
                </h1>
                <p class="mb-0 opacity-75">Quản lý nhà hàng của bạn</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="d-flex align-items-center justify-content-end">
                    <div class="me-3 text-end">
                        <small class="opacity-75">Hôm nay</small>
                        <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-tie me-2"></i>Quản lý
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Restaurant", new { area = "Restaurant" })"><i class="fas fa-building me-2"></i>Thông tin nhà hàng</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Settings", "Restaurant", new { area = "Restaurant" })"><i class="fas fa-cog me-2"></i>Cài đặt</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-2">
            <div class="restaurant-sidebar shadow-sm">
                <nav class="nav flex-column">
                    <a class="nav-link" href="@Url.Action("Index", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a class="nav-link" href="@Url.Action("Orders", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-shopping-cart me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Chat", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-comments me-2"></i>Chat
                    </a>
                    <a class="nav-link" href="@Url.Action("Analytics", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-chart-line me-2"></i>Thống kê
                    </a>
                    <a class="nav-link active" href="@Url.Action("Profile", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-building me-2"></i>Nhà hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Settings", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                </nav>
            </div>
        </div>

        <div class="col-md-10">
            <!-- Restaurant Info Summary Card -->
            <div class="card border-0 shadow-sm mb-4 bg-white overflow-hidden rounded-3">
                <div class="row g-0">
                    <div class="col-md-3">
                        <img src="@(string.IsNullOrEmpty(Model.Image) ? "https://res.cloudinary.com/dzrhf1hwk/image/upload/v1779271401/DAPM_32/restaurants/restaurant-1.jpg" : Model.Image)" 
                             class="w-100 h-100 img-cover" style="min-height: 150px; object-fit: cover;" alt="@Model.NameRestaurant" />
                    </div>
                    <div class="col-md-9">
                        <div class="card-body p-4 d-flex flex-column justify-content-center h-100">
                            <h3 class="card-title fw-bold text-dark mb-1">@Model.NameRestaurant</h3>
                            <p class="text-secondary mb-2" style="font-size: 0.95rem;">
                                <i class="fas fa-info-circle me-2 text-primary"></i>@Model.Description
                            </p>
                            <div class="d-flex flex-wrap gap-3 mt-1">
                                <span class="text-dark small"><i class="fas fa-map-marker-alt me-2 text-danger"></i>@Model.Address</span>
                                <span class="text-dark small"><i class="fas fa-clock me-2 text-warning"></i>@Model.OpenTime.ToString(@"hh\:mm") - @Model.CloseTime.ToString(@"hh\:mm")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Navigation & Hub -->
            <div class="card border-0 shadow-sm p-4 bg-white rounded-3">
                <ul class="nav nav-tabs border-bottom mb-4" id="restaurantHubTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold px-4 py-3" id="foods-tab" data-bs-toggle="tab" data-bs-target="#foods-pane" type="button" role="tab" aria-controls="foods-pane" aria-selected="true">
                            <i class="fas fa-utensils me-2"></i>Quản lý Món ăn (@foods.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold px-4 py-3" id="promotions-tab" data-bs-toggle="tab" data-bs-target="#promotions-pane" type="button" role="tab" aria-controls="promotions-pane" aria-selected="false">
                            <i class="fas fa-tags me-2"></i>Chương trình Khuyến mãi (@promotions.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold px-4 py-3" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews-pane" type="button" role="tab" aria-controls="reviews-pane" aria-selected="false">
                            <i class="fas fa-star text-warning me-2"></i>Đánh giá & Phản hồi (@reviews.Count)
                        </button>
                    </li>
                </ul>

                <div class="tab-content" id="restaurantHubTabsContent">
                    
                    <!-- TAB 1: FOODS CRUD -->
                    <div class="tab-pane fade show active" id="foods-pane" role="tabpanel" aria-labelledby="foods-tab" tabindex="0">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold text-dark m-0">Danh sách Món ăn</h4>
                            <button class="btn btn-success rounded-pill px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#createFoodModal">
                                <i class="fas fa-plus-circle me-2"></i>Thêm Món Mới
                            </button>
                        </div>

                        @if (foods.Count == 0)
                        {
                            <div class="text-center py-5">
                                <img src="https://res.cloudinary.com/dzrhf1hwk/image/upload/v1779271401/DAPM_32/foods/food-default.jpg" class="opacity-25 mb-3 rounded-circle" style="width: 100px; height: 100px; object-fit: cover;" alt="No Foods" />
                                <h5 class="text-muted">Chưa có món ăn nào trong thực đơn của nhà hàng</h5>
                                <p class="text-secondary small">Hãy thêm món ăn đầu tiên để bắt đầu đón nhận đơn hàng.</p>
                            </div>
                        }
                        else
                        {
                            <div class="row g-4">
                                @foreach (var food in foods)
                                {
                                    var category = categories.FirstOrDefault(c => c.IdCategory == food.IdCategory);
                                    var actualPrice = food.Price - (food.Discount ?? 0);
                                    <div class="col-md-6 col-lg-4">
                                        <div class="card h-100 border-0 shadow-sm food-card overflow-hidden bg-light rounded-3 transition">
                                            <div class="position-relative" style="height: 180px;">
                                                <img src="@(string.IsNullOrEmpty(food.Image) ? "https://res.cloudinary.com/dzrhf1hwk/image/upload/v1779271401/DAPM_32/foods/food-default.jpg" : food.Image)" class="w-100 h-100 img-cover" style="object-fit: cover;" alt="@food.Name" />
                                                @if (food.Discount.HasValue && food.Discount.Value > 0)
                                                {
                                                    <span class="position-absolute top-2 start-2 badge bg-danger rounded-pill px-2 py-1 shadow-sm">
                                                        <i class="fas fa-percentage me-1"></i>Giảm @food.Discount.Value.ToString("N0")đ
                                                    </span>
                                                }
                                                <span class="position-absolute bottom-2 end-2 badge bg-dark rounded-pill px-2 py-1 opacity-75">
                                                    @(category?.Name ?? "Khác")
                                                </span>
                                            </div>
                                            <div class="card-body p-3 d-flex flex-column justify-content-between">
                                                <div>
                                                    <h5 class="card-title fw-bold text-dark mb-1">@food.Name</h5>
                                                    <p class="card-text text-secondary small text-truncate-2 mb-3">@food.Description</p>
                                                    <div class="d-flex align-items-center mb-3">
                                                        @if (food.Discount.HasValue && food.Discount.Value > 0)
                                                        {
                                                            <span class="fs-5 fw-bold text-success me-2">@actualPrice.ToString("N0")đ</span>
                                                            <span class="small text-muted line-through">@food.Price.ToString("N0")đ</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="fs-5 fw-bold text-success">@food.Price.ToString("N0")đ</span>
                                                        }
                                                    </div>

                                                    <!-- Quản lý Số lượng Bán hôm nay -->
                                                    <div class="p-2 mb-3 bg-white border border-light-subtle rounded-3 shadow-sm">
                                                        <form action="@Url.Action("UpdateDailyQuantity", "Restaurant", new { area = "Restaurant" })" method="post" class="d-flex align-items-center justify-content-between gap-2">
                                                            <input type="hidden" name="idFood" value="@food.IdFood" />
                                                            <div class="d-flex align-items-center">
                                                                <i class="fas fa-cubes text-success me-2 small"></i>
                                                                <span class="small fw-bold text-secondary">Số lượng bán:</span>
                                                            </div>
                                                            <div class="d-flex align-items-center gap-1">
                                                                <input type="number" name="dailyQuantity" value="@food.DailyQuantity" class="form-control form-control-sm text-center fw-bold text-success border-success-subtle rounded-3" style="width: 70px; font-size: 0.85rem;" min="0" required />
                                                                <button type="submit" class="btn btn-sm btn-success rounded-3 px-2 py-1" style="font-size: 0.8rem;" title="Cập nhật số lượng">
                                                                    <i class="fas fa-save"></i>
                                                                </button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                                <div>
                                                    <div class="d-flex gap-2">
                                                        <button class="btn btn-outline-primary btn-sm flex-fill rounded-pill edit-food-btn" 
                                                                data-id="@food.IdFood" 
                                                                data-name="@food.Name" 
                                                                data-category="@food.IdCategory"
                                                                data-description="@food.Description" 
                                                                data-price="@food.Price" 
                                                                data-discount="@(food.Discount ?? 0)" 
                                                                data-image="@food.Image" 
                                                                data-video="@food.Video" 
                                                                data-preptime="@(food.PrepTime ?? 15)"
                                                                data-dailyquantity="@food.DailyQuantity"
                                                                data-bs-toggle="modal" 
                                                                data-bs-target="#editFoodModal">
                                                            <i class="fas fa-edit me-1"></i>Sửa
                                                        </button>
                                                        <button class="btn btn-outline-danger btn-sm flex-fill rounded-pill delete-food-btn" 
                                                                data-id="@food.IdFood"
                                                                data-name="@food.Name"
                                                                data-bs-toggle="modal" 
                                                                data-bs-target="#deleteFoodModal">
                                                            <i class="fas fa-trash-alt me-1"></i>Xóa
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- TAB 2: PROMOTIONS CRUD -->
                    <div class="tab-pane fade" id="promotions-pane" role="tabpanel" aria-labelledby="promotions-tab" tabindex="0">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold text-dark m-0">Chương trình Khuyến mãi toàn nhà hàng</h4>
                            <button class="btn btn-success rounded-pill px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#createPromoModal">
                                <i class="fas fa-plus-circle me-2"></i>Thêm Khuyến Mãi Mới
                            </button>
                        </div>

                        @if (promotions.Count == 0)
                        {
                            <div class="text-center py-5 bg-light rounded-3">
                                <i class="fas fa-gift text-secondary opacity-25 mb-3" style="font-size: 4rem;"></i>
                                <h5 class="text-muted">Chưa có mã khuyến mãi nào</h5>
                                <p class="text-secondary small">Tạo thêm các voucher giảm giá để thu hút nhiều khách hàng hơn.</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle table-borderless">
                                    <thead class="table-dark rounded-3">
                                        <tr>
                                            <th>Kiểu giảm</th>
                                            <th>Giá trị giảm</th>
                                            <th>Đơn tối thiểu</th>
                                            <th>Giảm tối đa</th>
                                            <th>Giới hạn lượt dùng</th>
                                            <th>Đã dùng</th>
                                            <th>Hiệu lực</th>
                                            <th class="text-end">Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var promo in promotions)
                                        {
                                            var isExpired = promo.EndDate < DateTime.Now;
                                            var isFull = promo.UsedCount >= promo.UsageLimit;
                                            var statusClass = isExpired ? "bg-secondary" : (isFull ? "bg-warning" : "bg-success");
                                            var statusText = isExpired ? "Hết hạn" : (isFull ? "Hết lượt" : "Đang chạy");
                                            
                                            <tr>
                                                <td>
                                                    <span class="badge bg-primary px-2 py-1 rounded-pill">
                                                        @(promo.Type == "PERCENTAGE" ? "Phần trăm" : "Cố định")
                                                    </span>
                                                </td>
                                                <td class="fw-bold text-success">
                                                    @(promo.Type == "PERCENTAGE" ? promo.Value.ToString("F0") + "%" : promo.Value.ToString("N0") + "đ")
                                                </td>
                                                <td>@promo.MinOrderValue.ToString("N0")đ</td>
                                                <td>@promo.MaxDiscount.ToString("N0")đ</td>
                                                <td>@promo.UsageLimit</td>
                                                <td>
                                                    <span class="fw-semibold">@promo.UsedCount</span>
                                                </td>
                                                <td class="small">
                                                    <div><i class="fas fa-calendar-alt text-success me-1"></i>Từ: @promo.StartDate.ToString("dd/MM/yyyy HH:mm")</div>
                                                    <div><i class="fas fa-calendar-alt text-danger me-1"></i>Đến: @promo.EndDate.ToString("dd/MM/yyyy HH:mm")</div>
                                                    <span class="badge @statusClass rounded-pill mt-1">@statusText</span>
                                                </td>
                                                <td class="text-end">
                                                    <div class="d-flex justify-content-end gap-2">
                                                        <button class="btn btn-sm btn-outline-primary rounded-pill edit-promo-btn" 
                                                                data-id="@promo.IdPromo"
                                                                data-type="@promo.Type"
                                                                data-value="@promo.Value"
                                                                data-minval="@promo.MinOrderValue"
                                                                data-maxdisc="@promo.MaxDiscount"
                                                                data-limit="@promo.UsageLimit"
                                                                data-used="@promo.UsedCount"
                                                                data-start="@promo.StartDate.ToString("yyyy-MM-ddTHH:mm")"
                                                                data-end="@promo.EndDate.ToString("yyyy-MM-ddTHH:mm")"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#editPromoModal">
                                                            <i class="fas fa-edit"></i>
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger rounded-pill delete-promo-btn"
                                                                data-id="@promo.IdPromo"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#deletePromoModal">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    <!-- TAB 3: REVIEWS & FEEDBACK -->
                    <div class="tab-pane fade" id="reviews-pane" role="tabpanel" aria-labelledby="reviews-tab" tabindex="0">
                        <style>
                            .review-card {
                                transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
                                border: 1px solid rgba(0, 0, 0, 0.08) !important;
                                border-radius: 12px !important;
                            }
                            .review-card:hover {
                                transform: translateY(-4px);
                                box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08) !important;
                            }
                            .order-header-bar {
                                background: linear-gradient(135deg, #f0f7f4, #e2f3ec);
                                border-bottom: 1px solid rgba(40, 167, 69, 0.08);
                                border-radius: 12px 12px 0 0;
                                padding: 12px 20px;
                            }
                            .rating-star-gold {
                                color: #ffc107;
                                text-shadow: 0 0 2px rgba(255, 193, 7, 0.25);
                            }
                            .rating-star-blue {
                                color: #0d6efd;
                                text-shadow: 0 0 2px rgba(13, 110, 253, 0.25);
                            }
                            .comment-bubble {
                                position: relative;
                                background: #ffffff;
                                border-radius: 8px;
                                padding: 12px 16px;
                                border-left: 4px solid #28a745;
                                box-shadow: 0 2px 6px rgba(0,0,0,0.03);
                            }
                            .comment-bubble-shipper {
                                border-left-color: #0d6efd;
                            }
                            .food-badge-item {
                                background: #f8f9fa;
                                border: 1px solid #dee2e6;
                                border-radius: 30px;
                                padding: 6px 16px;
                                font-size: 0.85rem;
                                transition: all 0.2s ease;
                            }
                            .food-badge-item:hover {
                                background: #e9ecef;
                                transform: scale(1.03);
                            }
                            .avatar-fallback {
                                font-weight: 700;
                                text-transform: uppercase;
                                letter-spacing: 0.5px;
                                background: linear-gradient(135deg, #28a745, #218838);
                            }
                        </style>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold text-dark m-0">Đánh giá & Phản hồi từ Thực khách</h4>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold" style="font-size: 1rem;">
                                    Điểm trung bình: 4.8 <i class="fas fa-star ms-1"></i>
                                </span>
                            </div>
                        </div>

                        @if (reviews.Count == 0)
                        {
                            <div class="text-center py-5 bg-light rounded-3">
                                <i class="fas fa-comment-slash text-secondary opacity-25 mb-3" style="font-size: 4rem;"></i>
                                <h5 class="text-muted">Chưa có đánh giá nào từ khách hàng</h5>
                                <p class="text-secondary small">Nhà hàng sẽ nhận được phản hồi sau khi shipper giao đơn hàng thành công.</p>
                            </div>
                        }
                        else
                        {
                            <div class="row g-4">
                                @foreach (var r in reviews)
                                {
                                    var initials = !string.IsNullOrEmpty(r.CustomerName) ? r.CustomerName.Substring(0, 1).ToUpper() : "?";
                                    
                                    <div class="col-12">
                                        <div class="card border-0 shadow-sm review-card bg-white mb-2">
                                            <!-- Gorgeous Order Context Header Bar -->
                                            <div class="order-header-bar d-flex flex-wrap align-items-center justify-content-between gap-3">
                                                <div class="d-flex align-items-center flex-wrap gap-3">
                                                    <span class="badge bg-success text-white rounded-pill px-3 py-1.5 fw-bold shadow-sm" style="font-size: 0.8rem;">
                                                        <i class="fas fa-box-open me-1.5"></i>Đơn hàng #@r.IdOrder
                                                    </span>
                                                    @if (!string.IsNullOrEmpty(r.OrderCode))
                                                    {
                                                        <span class="text-dark fw-semibold" style="font-size: 0.88rem;">
                                                            <i class="fas fa-receipt text-success me-1"></i>Mã hóa đơn: 
                                                            <code class="text-success bg-success-subtle px-2 py-0.5 rounded border border-success-subtle fw-bold" style="font-size: 0.85rem;">@r.OrderCode</code>
                                                        </span>
                                                    }
                                                </div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-1.5 fw-bold" style="font-size: 0.78rem;">
                                                        <i class="fas fa-check-circle me-1"></i>Giao hàng thành công
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="card-body p-4">
                                                <div class="row g-4">
                                                    <!-- Customer Details and Overall Ratings (Left Column) -->
                                                    <div class="col-lg-3 col-md-4 border-end">
                                                        <div class="d-flex align-items-center gap-3 mb-3">
                                                            <div class="avatar-wrapper position-relative" style="width: 54px; height: 54px; flex-shrink: 0;">
                                                                <img src="@(string.IsNullOrEmpty(r.CustomerAvatar) ? "https://res.cloudinary.com/dzrhf1hwk/image/upload/v1779271401/DAPM_32/users/default-user.jpg" : r.CustomerAvatar)" 
                                                                     class="rounded-circle border border-2 border-white shadow-sm w-100 h-100" 
                                                                     style="object-fit: cover; display: block;" 
                                                                     alt="" 
                                                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                                                <div class="avatar-fallback rounded-circle border border-2 border-white shadow-sm text-white fw-bold align-items-center justify-content-center" 
                                                                     style="width: 54px; height: 54px; font-size: 1.3rem; display: none;">
                                                                    @initials
                                                                </div>
                                                            </div>
                                                            <div>
                                                                <h6 class="fw-bold text-dark mb-0" style="font-size: 1rem;">@r.CustomerName</h6>
                                                                <small class="text-secondary d-block mt-1" style="font-size: 0.8rem;">
                                                                    <i class="far fa-clock me-1 text-muted"></i>@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                                                </small>
                                                            </div>
                                                        </div>

                                                        <!-- Food Rating -->
                                                        <div class="p-2 mb-2 bg-light rounded border border-light-subtle shadow-sm">
                                                            <div class="d-flex align-items-center justify-content-between">
                                                                <span class="fw-bold text-secondary small"><i class="fas fa-utensils text-success me-1"></i>Món ăn:</span>
                                                                <div class="text-warning rating-star-gold" style="font-size: 0.9rem;">
                                                                    @for (var i = 1; i <= 5; i++)
                                                                    {
                                                                        <i class="fa@(i <= Math.Round(r.FoodRating) ? "s" : "r") fa-star"></i>
                                                                    }
                                                                </div>
                                                            </div>
                                                            <div class="text-end mt-0.5">
                                                                <span class="fw-bold text-dark" style="font-size: 0.8rem;">@r.FoodRating / 5.0</span>
                                                            </div>
                                                        </div>

                                                        <!-- Driver Rating -->
                                                        <div class="p-2 bg-light rounded border border-light-subtle shadow-sm">
                                                            <div class="d-flex align-items-center justify-content-between">
                                                                <span class="fw-bold text-secondary small"><i class="fas fa-truck text-primary me-1"></i>Tài xế:</span>
                                                                <div class="text-primary rating-star-blue" style="font-size: 0.9rem;">
                                                                    @for (var i = 1; i <= 5; i++)
                                                                    {
                                                                        <i class="fa@(i <= Math.Round(r.DriverRating) ? "s" : "r") fa-star"></i>
                                                                    }
                                                                </div>
                                                            </div>
                                                            <div class="text-end mt-0.5">
                                                                <span class="fw-bold text-dark" style="font-size: 0.8rem;">@r.DriverRating / 5.0</span>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Detailed Reviews Text & Food Details (Right Column) -->
                                                    <div class="col-lg-9 col-md-8">
                                                        <!-- Restaurant Comment Bubble -->
                                                        <div class="mb-3">
                                                            <h6 class="fw-bold text-success mb-2 d-flex align-items-center gap-1.5" style="font-size: 0.85rem;">
                                                                <i class="fas fa-store-alt"></i> Phản hồi về Món ăn & Nhà hàng:
                                                            </h6>
                                                            <div class="comment-bubble text-dark" style="font-size: 0.95rem; font-style: italic;">
                                                                @r.CommentForRes
                                                            </div>
                                                        </div>

                                                        <!-- Shipper Comment Bubble -->
                                                        @if (!string.IsNullOrEmpty(r.CommentForShipper))
                                                        {
                                                            <div class="mb-3">
                                                                <h6 class="fw-bold text-primary mb-2 d-flex align-items-center gap-1.5" style="font-size: 0.85rem;">
                                                                    <i class="fas fa-biking"></i> Nhận xét về Tài xế & Giao nhận:
                                                                </h6>
                                                                <div class="comment-bubble comment-bubble-shipper text-secondary" style="font-size: 0.92rem; font-style: italic;">
                                                                    @r.CommentForShipper
                                                                </div>
                                                            </div>
                                                        }

                                                        <!-- Food Items Breakdown -->
                                                        @if (r.ReviewFoods != null && r.ReviewFoods.Any())
                                                        {
                                                            <div class="border-top pt-3 mt-3">
                                                                <h6 class="fw-bold text-secondary mb-2.5 d-flex align-items-center gap-1.5" style="font-size: 0.85rem;">
                                                                    <i class="fas fa-receipt"></i> Món ăn đã được đánh giá:
                                                                </h6>
                                                                <div class="d-flex flex-wrap gap-2">
                                                                    @foreach (var rf in r.ReviewFoods)
                                                                    {
                                                                        <div class="food-badge-item d-inline-flex align-items-center gap-2 shadow-sm bg-white">
                                                                            <i class="fas fa-hamburger text-warning" style="font-size: 0.8rem;"></i>
                                                                            <span class="fw-bold text-dark">@rf.FoodName:</span>
                                                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle fw-bold rounded-pill px-2 py-0.5" style="font-size: 0.75rem;">
                                                                                <i class="fas fa-star me-0.5" style="font-size: 0.7rem;"></i>@rf.Rating
                                                                            </span>
                                                                            @if (!string.IsNullOrEmpty(rf.Comment))
                                                                            {
                                                                                <span class="text-secondary border-start ps-2 py-0.5" style="font-size: 0.8rem; font-style: italic;">@rf.Comment</span>
                                                                            }
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

