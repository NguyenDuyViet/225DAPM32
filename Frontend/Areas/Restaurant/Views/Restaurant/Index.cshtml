@{
    ViewData["Title"] = "Dashboard Nhà hàng";
}

<!-- Restaurant Header -->
<div class="admin-header bg-dark text-white py-4 mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 mb-0">
                    <i class="fas fa-store me-3"></i>Dashboard Nhà hàng
                </h1>
                <p class="mb-0 opacity-75">Quản lý nhà hàng của bạn</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="d-flex align-items-center justify-content-end">
                    <div class="me-3 text-end">
                        <small class="opacity-75">Hôm nay</small>
                        <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-tie me-2"></i>Quản lý
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Restaurant")"><i class="fas fa-building me-2"></i>Thông tin nhà hàng</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Settings", "Restaurant")"><i class="fas fa-cog me-2"></i>Cài đặt</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-2">
            <div class="restaurant-sidebar">
                <nav class="nav flex-column">
                    <a class="nav-link active" href="@Url.Action("Index", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a class="nav-link" href="@Url.Action("Menu", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-utensils me-2"></i>Menu
                    </a>
                    <a class="nav-link" href="@Url.Action("Orders", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-shopping-cart me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Analytics", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-chart-line me-2"></i>Thống kê
                    </a>
                    <a class="nav-link" href="@Url.Action("Profile", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-building me-2"></i>Nhà hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Settings", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                </nav>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-10">
            <!-- Stats Cards -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-success">
                                    <i class="fas fa-shopping-cart"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">47</h3>
                                    <small class="text-muted">Đơn hàng hôm nay</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-primary">
                                    <i class="fas fa-dollar-sign"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">2.8M</h3>
                                    <small class="text-muted">Doanh thu hôm nay</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-warning">
                                    <i class="fas fa-clock"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">12</h3>
                                    <small class="text-muted">Đơn đang chuẩn bị</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-info">
                                    <i class="fas fa-star"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">4.7</h3>
                                    <small class="text-muted">Đánh giá trung bình</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Hành động nhanh</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <a href="@Url.Action("Menu", "Restaurant")" class="btn btn-outline-primary w-100 h-100 d-flex flex-column align-items-center py-4">
                                        <i class="fas fa-plus-circle fa-2x mb-2"></i>
                                        <span>Thêm món mới</span>
                                    </a>
                                </div>
                                <div class="col-md-3">
                                    <a href="@Url.Action("Orders", "Restaurant")" class="btn btn-outline-success w-100 h-100 d-flex flex-column align-items-center py-4">
                                        <i class="fas fa-list fa-2x mb-2"></i>
                                        <span>Xem đơn hàng</span>
                                    </a>
                                </div>
                                <div class="col-md-3">
                                    <a href="@Url.Action("Analytics", "Restaurant")" class="btn btn-outline-info w-100 h-100 d-flex flex-column align-items-center py-4">
                                        <i class="fas fa-chart-bar fa-2x mb-2"></i>
                                        <span>Xem báo cáo</span>
                                    </a>
                                </div>
                                <div class="col-md-3">
                                    <a href="@Url.Action("Profile", "Restaurant")" class="btn btn-outline-warning w-100 h-100 d-flex flex-column align-items-center py-4">
                                        <i class="fas fa-edit fa-2x mb-2"></i>
                                        <span>Cập nhật thông tin</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Orders -->
            <div class="row mb-4">
                <div class="col-md-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Đơn hàng gần đây</h5>
                            <a href="@Url.Action("Orders", "Restaurant")" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush">
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">#12345 - Nguyễn Văn A</h6>
                                            <small class="text-muted">2 Phở bò, 1 Cơm tấm • 185,000 VND</small>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-warning mb-1">Đang chuẩn bị</span>
                                            <br>
                                            <small class="text-muted">10:30 AM</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">#12344 - Trần Thị B</h6>
                                            <small class="text-muted">1 Bún bò Huế, 2 Trà đá • 145,000 VND</small>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-success mb-1">Đã giao</span>
                                            <br>
                                            <small class="text-muted">9:45 AM</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">#12343 - Lê Văn C</h6>
                                            <small class="text-muted">3 Phở gà, 1 Bánh mì • 220,000 VND</small>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-primary mb-1">Đã xác nhận</span>
                                            <br>
                                            <small class="text-muted">9:15 AM</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Trạng thái bếp</h5>
                        </div>
                        <div class="card-body">
                            <div class="kitchen-status">
                                <div class="status-item mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span>Đầu bếp chính</span>
                                        <span class="badge bg-success">Hoạt động</span>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar bg-success" style="width: 85%"></div>
                                    </div>
                                    <small class="text-muted">85% công suất</small>
                                </div>
                                <div class="status-item mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span>Nhân viên phục vụ</span>
                                        <span class="badge bg-warning">Bận rộn</span>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar bg-warning" style="width: 92%"></div>
                                    </div>
                                    <small class="text-muted">92% công suất</small>
                                </div>
                                <div class="status-item">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span>Khu vực giao hàng</span>
                                        <span class="badge bg-info">Bình thường</span>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar bg-info" style="width: 68%"></div>
                                    </div>
                                    <small class="text-muted">68% công suất</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Popular Items -->
            <div class="row">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Món ăn bán chạy nhất</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-3 mb-3">
                                    <div class="popular-item text-center">
                                        <img src="/images/pho.jpg" alt="Phở bò" class="img-fluid rounded mb-2">
                                        <h6>Phở bò</h6>
                                        <p class="text-success fw-bold mb-1">45,000 VND</p>
                                        <small class="text-muted">Đã bán: 23 phần</small>
                                    </div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <div class="popular-item text-center">
                                        <img src="/images/comtam.jpg" alt="Cơm tấm" class="img-fluid rounded mb-2">
                                        <h6>Cơm tấm</h6>
                                        <p class="text-success fw-bold mb-1">35,000 VND</p>
                                        <small class="text-muted">Đã bán: 18 phần</small>
                                    </div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <div class="popular-item text-center">
                                        <img src="/images/bunbo.jpg" alt="Bún bò Huế" class="img-fluid rounded mb-2">
                                        <h6>Bún bò Huế</h6>
                                        <p class="text-success fw-bold mb-1">40,000 VND</p>
                                        <small class="text-muted">Đã bán: 15 phần</small>
                                    </div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <div class="popular-item text-center">
                                        <img src="/images/goicuon.jpg" alt="Gỏi cuốn" class="img-fluid rounded mb-2">
                                        <h6>Gỏi cuốn</h6>
                                        <p class="text-success fw-bold mb-1">30,000 VND</p>
                                        <small class="text-muted">Đã bán: 12 phần</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.restaurant-header {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
}

.restaurant-sidebar {
    background: #f8f9fa;
    border-radius: 10px;
    padding: 20px 0;
    min-height: calc(100vh - 200px);
}

.restaurant-sidebar .nav-link {
    color: #495057;
    padding: 12px 20px;
    margin: 5px 15px;
    border-radius: 8px;
    transition: all 0.3s ease;
}

.restaurant-sidebar .nav-link:hover {
    background: #e9ecef;
    color: #212529;
}

.restaurant-sidebar .nav-link.active {
    background: #28a745;
    color: white;
}

.stats-card {
    border-radius: 10px;
    transition: transform 0.3s ease;
}

.stats-card:hover {
    transform: translateY(-2px);
}

.stats-icon {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
}

.kitchen-status .progress {
    height: 8px;
    margin-bottom: 5px;
}

.popular-item img {
    height: 120px;
    object-fit: cover;
}
</style>