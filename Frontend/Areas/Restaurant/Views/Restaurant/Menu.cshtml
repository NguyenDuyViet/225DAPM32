@model IEnumerable<_225DAPM32.Models.Food>
@{
    ViewData["Title"] = "Quản lý Menu";
}

<h2 class="mb-4">Quản lý Menu</h2>
<div class="row g-3">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <img src="@item.Image" class="card-img-top" alt="@item.Name" />
                <div class="card-body">
                    <h5 class="card-title">@item.Name</h5>
                    <p class="card-text text-muted">@item.Category</p>
                    <p class="card-text">@item.Description</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold">@item.Price.ToString("N0") VND</span>
                        <button class="btn btn-sm btn-primary">Chỉnh sửa</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>