@{
    ViewData["Title"] = "Thống kê";
    var selectedPeriod = (ViewBag.Period as string) ?? "week";
}

<div class="admin-header bg-dark text-white py-4 mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 mb-0">
                    <i class="fas fa-store me-3 text-success"></i>Dashboard Nhà hàng
                </h1>
                <p class="mb-0 opacity-75">Quản lý nhà hàng của bạn</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="d-flex align-items-center justify-content-end">
                    <div class="me-3 text-end">
                        <small class="opacity-75">Hôm nay</small>
                        <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-tie me-2"></i>Quản lý
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Restaurant", new { area = "Restaurant" })"><i class="fas fa-building me-2"></i>Thông tin nhà hàng</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Settings", "Restaurant", new { area = "Restaurant" })"><i class="fas fa-cog me-2"></i>Cài đặt</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                                    <button class="dropdown-item text-danger" type="submit"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-2">
            <div class="restaurant-sidebar shadow-sm">
                <nav class="nav flex-column">
                    <a class="nav-link" href="@Url.Action("Index", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a class="nav-link" href="@Url.Action("Orders", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-shopping-cart me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Chat", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-comments me-2"></i>Chat
                        <span class="chat-new-dot js-restaurant-chat-dot d-none" title="Có tin nhắn mới"></span>
                    </a>
                    <a class="nav-link active" href="@Url.Action("Analytics", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-chart-line me-2"></i>Thống kê
                    </a>
                    <a class="nav-link" href="@Url.Action("Profile", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-building me-2"></i>Nhà hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Settings", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                </nav>
            </div>
        </div>

        <div class="col-md-10">
            <div class="card border-0 shadow-sm bg-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                        <h2 class="mb-0 fw-bold text-dark"><i class="fas fa-chart-bar me-2 text-success"></i>Báo cáo & Thống kê</h2>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <div class="btn-group analytics-period" role="group" aria-label="Chọn chu kỳ thống kê">
                                <a class="btn btn-sm @(selectedPeriod == "week" ? "btn-success" : "btn-outline-success")"
                                   asp-area="Restaurant" asp-controller="Restaurant" asp-action="Analytics" asp-route-period="week">Tuần</a>
                                <a class="btn btn-sm @(selectedPeriod == "month" ? "btn-success" : "btn-outline-success")"
                                   asp-area="Restaurant" asp-controller="Restaurant" asp-action="Analytics" asp-route-period="month">Tháng</a>
                                <a class="btn btn-sm @(selectedPeriod == "year" ? "btn-success" : "btn-outline-success")"
                                   asp-area="Restaurant" asp-controller="Restaurant" asp-action="Analytics" asp-route-period="year">Năm</a>
                            </div>
                            <a asp-area="Restaurant" asp-controller="Restaurant" asp-action="ExportRevenueReport" class="btn btn-danger fw-semibold">
                                <i class="fas fa-file-pdf me-2"></i>Xuất PDF doanh thu 
                            </a>
                        </div>
                    </div>
                    
                    <div class="row g-4">
                        <div class="col-md-7">
                            <div class="card border-0 shadow-sm bg-light">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-3 gap-2 flex-wrap">
                                        <div>
                                            <h5 class="fw-bold mb-1 text-dark"><i class="fas fa-money-bill-wave me-2 text-success"></i>Doanh thu theo chu kỳ</h5>
                                            <small class="text-muted">Bấm vào từng cột để xem chi tiết đơn hàng</small>
                                        </div>
                                    </div>
                                    <div style="position: relative; height:320px;">
                                        <canvas id="restaurantRevenue"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="card border-0 shadow-sm bg-light">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-3 text-dark"><i class="fas fa-chart-pie me-2 text-primary"></i>Trạng thái đơn hàng</h5>
                                    <div style="position: relative; height:320px;">
                                        <canvas id="restaurantStatus"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm bg-light mt-4" id="revenueDetailCard">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
                                <div>
                                    <h5 class="fw-bold mb-1 text-dark"><i class="fas fa-receipt me-2 text-success"></i>Chi tiết cột doanh thu</h5>
                                    <div class="text-muted" id="detailPeriodText">Chọn một cột trên biểu đồ để xem đơn hàng.</div>
                                </div>
                                <div class="d-flex gap-4 text-end">
                                    <div>
                                        <small class="text-muted d-block">Đơn hợp lệ</small>
                                        <strong id="detailOrderCount">0</strong>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Doanh thu</small>
                                        <strong class="text-success" id="detailRevenue">0 đ</strong>
                                    </div>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Mã đơn</th>
                                            <th>Khách hàng</th>
                                            <th>Món</th>
                                            <th>Trạng thái</th>
                                            <th class="text-end">Tổng tiền</th>
                                            <th>Thời gian</th>
                                        </tr>
                                    </thead>
                                    <tbody id="detailOrderRows">
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-4">Chưa chọn cột doanh thu.</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.admin-header {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%) !important;
}

.restaurant-sidebar {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 20px 0;
    min-height: calc(100vh - 200px);
}

.restaurant-sidebar .nav-link {
    color: #475569;
    padding: 12px 20px;
    margin: 5px 15px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s ease;
}

.restaurant-sidebar .nav-link:hover {
    background: #e2e8f0;
    color: #0f172a;
}

.restaurant-sidebar .nav-link.active {
    background: #10b981;
    color: white;
}

.analytics-period .btn {
    min-width: 72px;
}

#restaurantRevenue {
    cursor: pointer;
}

#revenueDetailCard .table th {
    color: #475569;
    font-size: 0.78rem;
    text-transform: uppercase;
    white-space: nowrap;
}
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Biểu đồ doanh thu
            const revenueCtx = document.getElementById('restaurantRevenue');
            if (revenueCtx) {
                const dayLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.DayLabels ?? new List<string> { "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "Chủ nhật" }));
                const bucketKeys = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.BucketKeys ?? new List<string>()));
                const revenueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RevenueData ?? new List<decimal> { 0, 0, 0, 0, 0, 0, 0 }));
                const revenueDetails = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Details ?? new List<object>()));
                const detailByKey = new Map(revenueDetails.map(item => [item.Key, item]));

                const revenueChart = new Chart(revenueCtx, {
                    type: 'bar',
                    data: {
                        labels: dayLabels,
                        datasets: [{
                            label: 'Doanh thu (VND)',
                            data: revenueData,
                            backgroundColor: '#10b981',
                            borderColor: '#059669',
                            borderWidth: 1,
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        onHover: function(event, elements) {
                            event.native.target.style.cursor = elements.length ? 'pointer' : 'default';
                        },
                        onClick: function(event, elements) {
                            if (!elements.length) {
                                return;
                            }

                            const index = elements[0].index;
                            const key = bucketKeys[index];
                            const detail = detailByKey.get(key);
                            renderRevenueDetail(detail);
                        },
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return context.parsed.y.toLocaleString('vi-VN') + ' đ';
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value) {
                                        return value.toLocaleString('vi-VN') + ' đ';
                                    }
                                }
                            }
                        }
                    }
                });

                if (revenueDetails.length > 0) {
                    renderRevenueDetail(revenueDetails[revenueDetails.length - 1]);
                }
            }

            // Biểu đồ trạng thái đơn hàng
            const statusCtx = document.getElementById('restaurantStatus');
            if (statusCtx) {
                const statusLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusLabels ?? new List<string> { "Đã xác nhận", "Đang chuẩn bị", "Đã giao" }));
                const statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusData ?? new List<int> { 0, 0, 0 }));

                new Chart(statusCtx, {
                    type: 'doughnut',
                    data: {
                        labels: statusLabels,
                        datasets: [{
                            data: statusData,
                            backgroundColor: ['#0d6efd', '#ffc107', '#10b981'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    padding: 20,
                                    font: {
                                        weight: '600'
                                    }
                                }
                            }
                        }
                    }
                });
            }

            function renderRevenueDetail(detail) {
                const periodText = document.getElementById('detailPeriodText');
                const orderCount = document.getElementById('detailOrderCount');
                const revenue = document.getElementById('detailRevenue');
                const rows = document.getElementById('detailOrderRows');

                if (!detail || !rows) {
                    return;
                }

                periodText.textContent = `${formatDate(detail.StartDate)} - ${formatDate(detail.EndDate)} (${detail.Label})`;
                orderCount.textContent = (detail.RevenueOrderCount ?? 0).toLocaleString('vi-VN');
                revenue.textContent = formatCurrency(detail.Revenue ?? 0);

                const orders = detail.Orders || [];
                if (!orders.length) {
                    rows.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">Không có đơn hàng trong chu kỳ này.</td></tr>';
                    return;
                }

                rows.innerHTML = orders.map(order => `
                    <tr>
                        <td class="fw-semibold">${escapeHtml(order.OrderCode || '#' + order.IdOrder)}</td>
                        <td>${escapeHtml(order.CustomerName || 'Khách hàng')}</td>
                        <td class="text-muted">${escapeHtml(order.ItemsText || '')}</td>
                        <td><span class="badge ${getStatusClass(order.Status)}">${getStatusText(order.Status)}</span></td>
                        <td class="text-end fw-semibold">${formatCurrency(order.FinalTotal || 0)}</td>
                        <td>${formatDateTime(order.CreatedAt)}</td>
                    </tr>
                `).join('');
            }

            function formatCurrency(value) {
                return Number(value || 0).toLocaleString('vi-VN') + ' đ';
            }

            function formatDate(value) {
                return new Date(value).toLocaleDateString('vi-VN');
            }

            function formatDateTime(value) {
                return new Date(value).toLocaleString('vi-VN', {
                    hour: '2-digit',
                    minute: '2-digit',
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric'
                });
            }

            function getStatusText(status) {
                switch ((status || '').toLowerCase()) {
                    case 'pending': return 'Chờ xử lý';
                    case 'confirmed': return 'Đã xác nhận';
                    case 'preparing': return 'Đang chuẩn bị';
                    case 'ready_for_pickup':
                    case 'cooked': return 'Chờ shipper lấy';
                    case 'delivering': return 'Đang giao';
                    case 'completed': return 'Hoàn thành';
                    case 'cancelled':
                    case 'canceled': return 'Đã hủy';
                    default: return status || 'Không rõ';
                }
            }

            function getStatusClass(status) {
                switch ((status || '').toLowerCase()) {
                    case 'completed': return 'bg-success';
                    case 'cancelled':
                    case 'canceled': return 'bg-danger';
                    case 'delivering': return 'bg-primary';
                    case 'preparing':
                    case 'ready_for_pickup':
                    case 'cooked': return 'bg-warning text-dark';
                    default: return 'bg-secondary';
                }
            }

            function escapeHtml(value) {
                const div = document.createElement('div');
                div.textContent = value;
                return div.innerHTML;
            }
        });
    </script>
}
