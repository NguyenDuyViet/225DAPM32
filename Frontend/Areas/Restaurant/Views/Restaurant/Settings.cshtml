@model _225DAPM32.Models.Restaurant
@{
    ViewData["Title"] = "Cài đặt";
}

<div class="admin-header bg-dark text-white py-4 mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 mb-0">
                    <i class="fas fa-store me-3 text-success"></i>Dashboard Nhà hàng
                </h1>
                <p class="mb-0 opacity-75">Quản lý nhà hàng của bạn</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="d-flex align-items-center justify-content-end">
                    <div class="me-3 text-end">
                        <small class="opacity-75">Hôm nay</small>
                        <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-tie me-2"></i>Quản lý
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Restaurant", new { area = "Restaurant" })"><i class="fas fa-building me-2"></i>Thông tin nhà hàng</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Settings", "Restaurant", new { area = "Restaurant" })"><i class="fas fa-cog me-2"></i>Cài đặt</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-2">
            <div class="restaurant-sidebar shadow-sm">
                <nav class="nav flex-column">
                    <a class="nav-link" href="@Url.Action("Index", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a class="nav-link" href="@Url.Action("Orders", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-shopping-cart me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Chat", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-comments me-2"></i>Chat
                    </a>
                    <a class="nav-link" href="@Url.Action("Analytics", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-chart-line me-2"></i>Thống kê
                    </a>
                    <a class="nav-link" href="@Url.Action("Profile", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-building me-2"></i>Nhà hàng
                    </a>
                    <a class="nav-link active" href="@Url.Action("Settings", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                </nav>
            </div>
        </div>

        <div class="col-md-10">
            <div class="card border-0 shadow-sm p-4 bg-white rounded-3">
                <h2 class="mb-4 fw-bold text-dark"><i class="fas fa-cog me-2 text-success"></i>Cài đặt Nhà hàng</h2>
                <form action="@Url.Action("SaveSettings", "Restaurant", new { area = "Restaurant" })" method="post">
                    <div class="row mb-4">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label for="nameRestaurant" class="form-label fw-bold">Tên nhà hàng</label>
                                <input type="text" class="form-control rounded-3" id="nameRestaurant" name="nameRestaurant" value="@Model.NameRestaurant" required />
                            </div>
                            <div class="mb-3">
                                <label for="image" class="form-label fw-bold">Đường dẫn hình ảnh (URL)</label>
                                <input type="text" class="form-control rounded-3" id="image" name="image" value="@Model.Image" placeholder="https://..." oninput="document.getElementById('avatar-preview').src = this.value || 'https://res.cloudinary.com/dzrhf1hwk/image/upload/v1779271401/DAPM_32/restaurants/restaurant-1.jpg'" />
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <label class="form-label fw-bold d-block">Ảnh đại diện nhà hàng</label>
                            <img id="avatar-preview" src="@(string.IsNullOrEmpty(Model.Image) ? "https://res.cloudinary.com/dzrhf1hwk/image/upload/v1779271401/DAPM_32/restaurants/restaurant-1.jpg" : Model.Image)" class="rounded-3 shadow-sm border img-thumbnail" style="width: 180px; height: 120px; object-fit: cover;" alt="Preview" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="description" class="form-label fw-bold">Mô tả giới thiệu</label>
                        <textarea class="form-control rounded-3" id="description" name="description" rows="3" required>@Model.Description</textarea>
                    </div>

                    <div class="mb-4">
                        <label for="address" class="form-label fw-bold">Địa chỉ</label>
                        <input type="text" class="form-control rounded-3" id="address" name="address" value="@Model.Address" required />
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label for="openTime" class="form-label fw-bold">Giờ mở cửa (HH:mm)</label>
                            <input type="text" class="form-control rounded-3" id="openTime" name="openTime" value="@Model.OpenTime.ToString(@"hh\:mm")" required placeholder="08:00" />
                            <small class="text-muted">Nhập định dạng 24 giờ (Ví dụ: 08:00, 10:30)</small>
                        </div>
                        <div class="col-md-6">
                            <label for="closeTime" class="form-label fw-bold">Giờ đóng cửa (HH:mm)</label>
                            <input type="text" class="form-control rounded-3" id="closeTime" name="closeTime" value="@Model.CloseTime.ToString(@"hh\:mm")" required placeholder="22:00" />
                            <small class="text-muted">Nhập định dạng 24 giờ (Ví dụ: 21:00, 22:30)</small>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Phương thức thanh toán</label>
                            <input type="text" class="form-control rounded-3 bg-light" value="Tiền mặt (COD), Thẻ tín dụng, Ví điện tử" readonly disabled />
                            <small class="text-muted">Được quản lý bởi hệ thống đối tác.</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Thời gian chuẩn bị trung bình</label>
                            <input type="text" class="form-control rounded-3 bg-light" value="15 - 20 phút" readonly disabled />
                            <small class="text-muted">Tự động tính toán dựa trên dữ liệu đơn hàng.</small>
                        </div>
                    </div>
                    
                    <div class="border-top pt-4 text-end">
                        <button type="submit" class="btn btn-success px-4 py-2 rounded-pill fw-bold">
                            <i class="fas fa-save me-2"></i>Lưu cài đặt
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
.admin-header {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%) !important;
}

.restaurant-sidebar {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 20px 0;
    min-height: calc(100vh - 200px);
}

.restaurant-sidebar .nav-link {
    color: #475569;
    padding: 12px 20px;
    margin: 5px 15px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s ease;
}

.restaurant-sidebar .nav-link:hover {
    background: #e2e8f0;
    color: #0f172a;
}

.restaurant-sidebar .nav-link.active {
    background: #10b981;
    color: white;
}
</style>