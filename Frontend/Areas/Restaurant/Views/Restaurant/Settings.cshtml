@{
    ViewData["Title"] = "Cài đặt";
}

<div class="admin-header bg-dark text-white py-4 mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 mb-0">
                    <i class="fas fa-store me-3"></i>Dashboard Nhà hàng
                </h1>
                <p class="mb-0 opacity-75">Quản lý nhà hàng của bạn</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="d-flex align-items-center justify-content-end">
                    <div class="me-3 text-end">
                        <small class="opacity-75">Hôm nay</small>
                        <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-tie me-2"></i>Quản lý
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Restaurant")"><i class="fas fa-building me-2"></i>Thông tin nhà hàng</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Settings", "Restaurant")"><i class="fas fa-cog me-2"></i>Cài đặt</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2">
            <div class="restaurant-sidebar">
                <nav class="nav flex-column">
                    <a class="nav-link" href="@Url.Action("Index", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a class="nav-link" href="@Url.Action("Orders", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-shopping-cart me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Analytics", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-chart-line me-2"></i>Thống kê
                    </a>
                    <a class="nav-link" href="@Url.Action("Profile", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-building me-2"></i>Nhà hàng
                    </a>
                    <a class="nav-link active" href="@Url.Action("Settings", "Restaurant", new { area = "Restaurant" })">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                </nav>
            </div>
        </div>

        <div class="col-md-10">
            <div class="card border-0 shadow-sm p-4">
                <h2 class="mb-4">Cài đặt Nhà hàng</h2>
                <form>
                    <div class="mb-3 row align-items-center">
                        <label class="col-sm-3 col-form-label">Mở / Đóng cửa</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" value="06:00 - 22:00" />
                        </div>
                    </div>
                    <div class="mb-3 row align-items-center">
                        <label class="col-sm-3 col-form-label">Phương thức thanh toán</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" value="Tiền mặt, Thẻ" />
                        </div>
                    </div>
                    <div class="mb-3 row align-items-center">
                        <label class="col-sm-3 col-form-label">Thời gian chuẩn bị</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" value="15 - 20 phút" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success">Lưu cài đặt</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
.restaurant-header { background: linear-gradient(135deg, #28a745 0%, #20c997 100%); }
.restaurant-sidebar { background: #f8f9fa; border-radius: 10px; padding: 20px 0; min-height: calc(100vh - 200px); }
.restaurant-sidebar .nav-link { color: #495057; padding: 12px 20px; margin: 5px 15px; border-radius: 8px; transition: all 0.3s ease; }
.restaurant-sidebar .nav-link:hover { background: #e9ecef; color: #212529; }
.restaurant-sidebar .nav-link.active { background: #28a745; color: white; }
</style>