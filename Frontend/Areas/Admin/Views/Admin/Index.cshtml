@{
    ViewData["Title"] = "Tổng quan Admin";
}

<div class="row mb-4 pt-3">
    <div class="col-md-3">
        <div class="card stats-card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stats-icon bg-primary">
                        <i class="fas fa-utensils"></i>
                    </div>
                    <div class="ms-3">
                        <h3 class="mb-0">1,247</h3>
                        <small class="text-muted">Nhà hàng</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stats-icon bg-success">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="ms-3">
                        <h3 class="mb-0">15,632</h3>
                        <small class="text-muted">Người dùng</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stats-icon bg-warning">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <div class="ms-3">
                        <h3 class="mb-0">8,549</h3>
                        <small class="text-muted">Đơn hàng hôm nay</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stats-icon bg-info">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                    <div class="ms-3">
                        <h3 class="mb-0">2.4M</h3>
                        <small class="text-muted">Doanh thu hôm nay</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">Doanh thu 7 ngày qua</h5>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="300"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">Trạng thái đơn hàng</h5>
            </div>
            <div class="card-body">
                <canvas id="orderStatusChart" height="300"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Đơn hàng gần đây</h5>
                <a href="@Url.Action("Orders", "Admin")" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1">#12345</h6>
                                <small class="text-muted">Phở 24 - Nguyễn Văn A</small>
                            </div>
                            <span class="badge bg-warning">Đang giao</span>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1">#12344</h6>
                                <small class="text-muted">Pizza Hut - Trần Thị B</small>
                            </div>
                            <span class="badge bg-success">Hoàn thành</span>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1">#12343</h6>
                                <small class="text-muted">Sushi World - Lê Văn C</small>
                            </div>
                            <span class="badge bg-primary">Đã xác nhận</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">Nhà hàng mới đăng ký</h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <div class="list-group-item">
                        <div class="d-flex align-items-center">
                            <img src="/images/restaurant1.jpg" alt="Restaurant" class="rounded-circle me-3" style="width: 40px; height: 40px;">
                            <div>
                                <h6 class="mb-1">Quán Cơm Mẹ Nấu</h6>
                                <small class="text-muted">Đăng ký 2 giờ trước</small>
                            </div>
                            <span class="badge bg-warning ms-auto">Chờ duyệt</span>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex align-items-center">
                            <img src="/images/restaurant2.jpg" alt="Restaurant" class="rounded-circle me-3" style="width: 40px; height: 40px;">
                            <div>
                                <h6 class="mb-1">Trà Sữa Tươi</h6>
                                <small class="text-muted">Đăng ký hôm qua</small>
                            </div>
                            <span class="badge bg-success ms-auto">Đã duyệt</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.stats-card {
    border-radius: 10px;
    transition: transform 0.3s ease;
}

.stats-card:hover {
    transform: translateY(-2px);
}

.stats-icon {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
}
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Revenue Chart
        const revenueCtx = document.getElementById('revenueChart').getContext('2d');
        new Chart(revenueCtx, {
            type: 'line',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                datasets: [{
                    label: 'Doanh thu (VND)',
                    data: [1200000, 1500000, 1800000, 1400000, 2000000, 2200000, 1900000],
                    borderColor: '#007bff',
                    backgroundColor: 'rgba(0, 123, 255, 0.1)',
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false
            }
        });

        // Order Status Chart
        const statusCtx = document.getElementById('orderStatusChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Hoàn thành', 'Đang giao', 'Đã xác nhận', 'Chờ xử lý'],
                datasets: [{
                    data: [45, 25, 20, 10],
                    backgroundColor: ['#28a745', '#ffc107', '#007bff', '#6c757d']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false
            }
        });
    });
    </script>
}
