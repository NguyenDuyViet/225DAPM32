@model _225DAPM32.Areas.Admin.Models.AdminDashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Tổng quan Admin";
    string imageUrl(string? image) => string.IsNullOrWhiteSpace(image)
        ? "/images/placeholder-restaurant.svg"
        : (image.StartsWith("http", StringComparison.OrdinalIgnoreCase) || image.StartsWith("/") ? image : "/" + image);
}

<div class="row mb-4 pt-3">
    <div class="col-md-3">
        <div class="card stats-card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="stats-icon bg-primary"><i class="fas fa-utensils"></i></div>
                <div class="ms-3"><h3 class="mb-0">@Model.RestaurantsCount.ToString("N0")</h3><small class="text-muted">Nhà hàng</small></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="stats-icon bg-success"><i class="fas fa-users"></i></div>
                <div class="ms-3"><h3 class="mb-0">@Model.UsersCount.ToString("N0")</h3><small class="text-muted">Người dùng</small></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="stats-icon bg-warning"><i class="fas fa-shopping-cart"></i></div>
                <div class="ms-3"><h3 class="mb-0">@Model.OrdersToday.ToString("N0")</h3><small class="text-muted">Đơn hàng hôm nay</small></div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light"><h5 class="mb-0">Trạng thái đơn hàng</h5></div>
            <div class="card-body"><canvas id="orderStatusChart" height="300"></canvas></div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Đơn hàng gần đây</h5>
                <a asp-area="Admin" asp-controller="Admin" asp-action="Orders" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.RecentOrders.Any())
                {
                    <p class="text-muted text-center py-4 mb-0">Chưa có đơn hàng.</p>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var order in Model.RecentOrders)
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">@(!string.IsNullOrWhiteSpace(order.OrderCode) ? order.OrderCode : $"#{order.IdOrder}")</h6>
                                        <small class="text-muted">@order.RestaurantName - @order.FinalTotal.ToString("N0") đ</small>
                                    </div>
                                    <span class="badge bg-@order.StatusColor">@order.StatusText</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light"><h5 class="mb-0">Nhà hàng trong hệ thống</h5></div>
            <div class="card-body p-0">
                @if (!Model.RecentRestaurants.Any())
                {
                    <p class="text-muted text-center py-4 mb-0">Chưa có nhà hàng.</p>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var restaurant in Model.RecentRestaurants)
                        {
                            <div class="list-group-item d-flex align-items-center">
                                <img src="@imageUrl(restaurant.Image)" onerror="this.onerror=null;this.src='/images/placeholder-restaurant.svg';" alt="@restaurant.NameRestaurant" class="rounded-circle me-3 object-fit-cover" style="width: 40px; height: 40px;" />
                                <div>
                                    <h6 class="mb-1">@restaurant.NameRestaurant</h6>
                                    <small class="text-muted">@restaurant.Address</small>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .stats-card { border-radius: 10px; transition: transform 0.3s ease; }
    .stats-card:hover { transform: translateY(-2px); }
    .stats-icon { width: 60px; height: 60px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: white; font-size: 24px; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new Chart(document.getElementById('orderStatusChart').getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(JsonSerializer.Serialize(Model.StatusLabels)),
                    datasets: [{
                        data: @Html.Raw(JsonSerializer.Serialize(Model.StatusData)),
                        backgroundColor: ['#28a745', '#ffc107', '#007bff', '#6c757d', '#dc3545']
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });
        });
    </script>
}
