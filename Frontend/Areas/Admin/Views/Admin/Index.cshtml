@{
    ViewData["Title"] = "Admin Dashboard";
}

<!-- Admin Header -->
<div class="admin-header bg-dark text-white py-4 mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 mb-0">
                    <i class="fas fa-tachometer-alt me-3"></i>Admin Dashboard
                </h1>
                <p class="mb-0 opacity-75">Quản lý hệ thống Món Ngon Tại Nhà</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="d-flex align-items-center justify-content-end">
                    <div class="me-3">
                        <small class="opacity-75">Hôm nay</small>
                        <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-shield me-2"></i>Admin
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#"><i class="fas fa-user me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item" href="#"><i class="fas fa-cog me-2"></i>Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-2">
            <div class="admin-sidebar">
                <nav class="nav flex-column">
                    <a class="nav-link active" href="@Url.Action("Index", "Admin", new { area = "Admin" })">
                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a class="nav-link" href="@Url.Action("Restaurants", "Admin", new { area = "Admin" })">
                        <i class="fas fa-utensils me-2"></i>Nhà hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Users", "Admin", new { area = "Admin" })">
                        <i class="fas fa-users me-2"></i>Người dùng
                    </a>
                    <a class="nav-link" href="@Url.Action("Policies", "Admin", new { area = "Admin" })">
                        <i class="fas fa-shield-alt me-2"></i>Chính sách bảo mật
                    </a>
                    <a class="nav-link" href="@Url.Action("Violations", "Admin", new { area = "Admin" })">
                        <i class="fas fa-exclamation-triangle me-2"></i>Cảnh báo vi phạm
                    </a>
                    <a class="nav-link" href="@Url.Action("Orders", "Admin", new { area = "Admin" })">
                        <i class="fas fa-shopping-cart me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Reports", "Admin", new { area = "Admin" })">
                        <i class="fas fa-chart-bar me-2"></i>Báo cáo
                    </a>
                    <a class="nav-link" href="@Url.Action("Settings", "Admin", new { area = "Admin" })">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                </nav>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-10">
            <!-- Stats Cards -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-primary">
                                    <i class="fas fa-utensils"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">1,247</h3>
                                    <small class="text-muted">Nhà hàng</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-success">
                                    <i class="fas fa-users"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">15,632</h3>
                                    <small class="text-muted">Người dùng</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-warning">
                                    <i class="fas fa-shopping-cart"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">8,549</h3>
                                    <small class="text-muted">Đơn hàng hôm nay</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="stats-icon bg-info">
                                    <i class="fas fa-dollar-sign"></i>
                                </div>
                                <div class="ms-3">
                                    <h3 class="mb-0">2.4M</h3>
                                    <small class="text-muted">Doanh thu hôm nay</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts Row -->
            <div class="row mb-4">
                <div class="col-md-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Doanh thu 7 ngày qua</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="revenueChart" height="300"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Trạng thái đơn hàng</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="orderStatusChart" height="300"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Orders -->
            <div class="row">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Đơn hàng gần đây</h5>
                            <a href="@Url.Action("Orders", "Admin")" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush">
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">#12345</h6>
                                            <small class="text-muted">Phở 24 - Nguyễn Văn A</small>
                                        </div>
                                        <span class="badge bg-warning">Đang giao</span>
                                    </div>
                                </div>
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">#12344</h6>
                                            <small class="text-muted">Pizza Hut - Trần Thị B</small>
                                        </div>
                                        <span class="badge bg-success">Hoàn thành</span>
                                    </div>
                                </div>
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">#12343</h6>
                                            <small class="text-muted">Sushi World - Lê Văn C</small>
                                        </div>
                                        <span class="badge bg-primary">Đã xác nhận</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Nhà hàng mới đăng ký</h5>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush">
                                <div class="list-group-item">
                                    <div class="d-flex align-items-center">
                                        <img src="/images/restaurant1.jpg" alt="Restaurant" class="rounded-circle me-3" style="width: 40px; height: 40px;">
                                        <div>
                                            <h6 class="mb-1">Quán Cơm Mẹ Nấu</h6>
                                            <small class="text-muted">Đăng ký 2 giờ trước</small>
                                        </div>
                                        <span class="badge bg-warning ms-auto">Chờ duyệt</span>
                                    </div>
                                </div>
                                <div class="list-group-item">
                                    <div class="d-flex align-items-center">
                                        <img src="/images/restaurant2.jpg" alt="Restaurant" class="rounded-circle me-3" style="width: 40px; height: 40px;">
                                        <div>
                                            <h6 class="mb-1">Trà Sữa Tươi</h6>
                                            <small class="text-muted">Đăng ký hôm qua</small>
                                        </div>
                                        <span class="badge bg-success ms-auto">Đã duyệt</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.admin-header {
    background: linear-gradient(135deg, #343a40 0%, #495057 100%);
}

.admin-sidebar {
    background: #f8f9fa;
    border-radius: 10px;
    padding: 20px 0;
    min-height: calc(100vh - 200px);
}

.admin-sidebar .nav-link {
    color: #495057;
    padding: 12px 20px;
    margin: 5px 15px;
    border-radius: 8px;
    transition: all 0.3s ease;
}

.admin-sidebar .nav-link:hover {
    background: #e9ecef;
    color: #212529;
}

.admin-sidebar .nav-link.active {
    background: #007bff;
    color: white;
}

.stats-card {
    border-radius: 10px;
    transition: transform 0.3s ease;
}

.stats-card:hover {
    transform: translateY(-2px);
}

.stats-icon {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Revenue Chart
    const revenueCtx = document.getElementById('revenueChart').getContext('2d');
    new Chart(revenueCtx, {
        type: 'line',
        data: {
            labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
            datasets: [{
                label: 'Doanh thu (VND)',
                data: [1200000, 1500000, 1800000, 1400000, 2000000, 2200000, 1900000],
                borderColor: '#007bff',
                backgroundColor: 'rgba(0, 123, 255, 0.1)',
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });

    // Order Status Chart
    const statusCtx = document.getElementById('orderStatusChart').getContext('2d');
    new Chart(statusCtx, {
        type: 'doughnut',
        data: {
            labels: ['Hoàn thành', 'Đang giao', 'Đã xác nhận', 'Chờ xử lý'],
            datasets: [{
                data: [45, 25, 20, 10],
                backgroundColor: ['#28a745', '#ffc107', '#007bff', '#6c757d']
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });
});
</script>