@{
    ViewData["Title"] = "Cài đặt Hệ thống";
}

<h2 class="mb-4">Cài đặt Hệ thống</h2>
<form>
    <div class="mb-3 row align-items-center">
        <label class="col-sm-3 col-form-label">Tên nền tảng</label>
        <div class="col-sm-9">
            <input type="text" class="form-control" value="Món Ngon Tại Nhà" />
        </div>
    </div>
    <div class="mb-3 row align-items-center">
        <label class="col-sm-3 col-form-label">Email hỗ trợ</label>
        <div class="col-sm-9">
            <input type="email" class="form-control" value="support@example.com" />
        </div>
    </div>
    <div class="mb-3 row align-items-center">
        <label class="col-sm-3 col-form-label">Số điện thoại hỗ trợ</label>
        <div class="col-sm-9">
            <input type="text" class="form-control" value="1900 1234" />
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
</form>