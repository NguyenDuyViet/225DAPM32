@{
    ViewData["Title"] = "Báo cáo vận hành";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0">Báo cáo vận hành</h2>
    <span class="badge bg-light text-dark border">Cập nhật hôm nay</span>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <i class="fas fa-receipt fa-2x text-primary mb-3"></i>
                <h5>Đơn hàng</h5>
                <p class="text-muted">Theo dõi trạng thái xử lý, giao hàng và hủy đơn.</p>
                <a asp-area="Admin" asp-controller="Admin" asp-action="Orders" class="btn btn-outline-primary">Xem đơn hàng</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <i class="fas fa-store fa-2x text-success mb-3"></i>
                <h5>Nhà hàng</h5>
                <p class="text-muted">Duyệt và bổ sung nhà hàng tham gia hệ thống.</p>
                <a asp-area="Admin" asp-controller="Admin" asp-action="Restaurants" class="btn btn-outline-success">Quản lý nhà hàng</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <i class="fas fa-motorcycle fa-2x text-warning mb-3"></i>
                <h5>Shipper</h5>
                <p class="text-muted">Cấp tài khoản và kiểm soát lực lượng giao hàng.</p>
                <a asp-area="Admin" asp-controller="Admin" asp-action="Shippers" class="btn btn-outline-warning">Quản lý shipper</a>
            </div>
        </div>
    </div>
</div>
