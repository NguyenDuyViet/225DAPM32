@model IEnumerable<_225DAPM32.Areas.Admin.Models.SecurityPolicyViewModel>
@{
    ViewData["Title"] = "Chính sách bảo mật";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0">Chính sách bảo mật</h2>
    <button class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Thêm chính sách mới
    </button>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <p class="mb-0">Quản lý các chính sách bảo mật áp dụng cho toàn hệ thống, bao gồm xác thực, kiểm soát truy cập và quy tắc xử lý dữ liệu.</p>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle admin-table">
        <thead class="table-light">
            <tr>
                <th>Chính sách</th>
                <th>Hiệu lực từ</th>
                <th>Trạng thái</th>
                <th>Mô tả</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var policy in Model)
            {
                var modalId = $"policyDetail{policy.Id}";

                <tr>
                    <td class="fw-semibold">@policy.Title</td>
                    <td>@policy.EffectiveDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (policy.IsActive)
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Không hoạt động</span>
                        }
                    </td>
                    <td>@policy.Description</td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#@modalId">
                            <i class="fas fa-eye me-1"></i>Xem chi tiết
                        </button>
                    </td>
                </tr>

                <div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@(modalId)Label" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="@(modalId)Label">Chi tiết chính sách #@policy.Id</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <div class="text-muted small">Tên chính sách</div>
                                    <div class="fw-semibold">@policy.Title</div>
                                </div>
                                <div class="mb-3">
                                    <div class="text-muted small">Ngày hiệu lực</div>
                                    <div>@policy.EffectiveDate.ToString("dd/MM/yyyy")</div>
                                </div>
                                <div class="mb-3">
                                    <div class="text-muted small">Trạng thái</div>
                                    <span class="badge @(policy.IsActive ? "bg-success" : "bg-secondary")">@(policy.IsActive ? "Hoạt động" : "Không hoạt động")</span>
                                </div>
                                <div>
                                    <div class="text-muted small">Nội dung</div>
                                    <div>@policy.Description</div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </tbody>
    </table>
</div>
