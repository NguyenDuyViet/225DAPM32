@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản lý Dịch vụ Món Ngon</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            font-family: 'Nunito', sans-serif;
            background-color: #fcfcfc;
        }

        .admin-header {
            background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
            box-shadow: 0 4px 15px rgba(255, 107, 107, 0.2);
        }

        .admin-sidebar {
            background: #fff5f2;
            border-radius: 20px;
            padding: 25px 10px;
            min-height: calc(100vh - 130px);
            box-shadow: inset 0 0 10px rgba(255, 107, 107, 0.05);
            border: 1px solid #ffe5de;
        }

        .admin-sidebar .nav-link {
            color: #8d6e63;
            padding: 14px 20px;
            margin: 6px 10px;
            border-radius: 15px;
            font-weight: 700;
            transition: all 0.3s ease;
        }

        .admin-sidebar .nav-link:hover {
            background: #ffebe6;
            color: #ff6b6b;
            transform: scale(1.02);
        }

        .admin-sidebar .nav-link.active {
            background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
            color: white !important;
            box-shadow: 0 8px 15px rgba(255, 107, 107, 0.25);
        }

        .admin-sidebar .nav-link i {
            width: 28px;
            font-size: 1.2rem;
        }

        .admin-table th,
        .admin-table td {
            text-align: center;
            vertical-align: middle;
        }

        .admin-table .cell-main {
            text-align: center;
        }

        .admin-actions {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
    </style>
</head>
<body>
    <header class="admin-header text-white py-3 mb-4">
        <div class="container-fluid">
            <div class="row align-items-center px-2">
                <div class="col-md-6">
                    <h2 class="h4 mb-0 fw-bold">
                        <i class="fas fa-layer-group me-3"></i>Hệ thống Quản trị
                    </h2>
                </div>
                <div class="col-md-6 text-end">
                    <div class="d-flex align-items-center justify-content-end">
                        <div class="me-4 text-end">
                            <small class="opacity-75 d-block" style="font-size: 0.8rem;">Hôm nay</small>
                            <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-light bg-white border-0 shadow-sm dropdown-toggle rounded-pill px-3 py-2" type="button" data-bs-toggle="dropdown" style="color: #ff6b6b; font-weight: 600;">
                                <i class="fas fa-user-shield me-2"></i>Admin
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow mt-2 rounded-3">
                                <li><a class="dropdown-item py-2" href="#"><i class="fas fa-user me-2 text-muted"></i>Hồ sơ cá nhân</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid px-4">
        <div class="row g-4">
            <div class="col-md-2">
                <div class="admin-sidebar shadow-sm">
                    <nav class="nav flex-column">
                        <a class="nav-link @(currentAction == "Index" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Index">
                            <i class="fas fa-chart-line me-2"></i>Tổng quan
                        </a>
                        <a class="nav-link @(currentAction == "Restaurants" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Restaurants">
                            <i class="fas fa-store me-2"></i>Nhà hàng
                        </a>
                        <a class="nav-link @(currentAction == "Users" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Users">
                            <i class="fas fa-user-friends me-2"></i>Người dùng
                        </a>
                        <a class="nav-link @(currentAction == "Policies" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Policies">
                            <i class="fas fa-shield-alt me-2"></i>Chính sách
                        </a>
                        <a class="nav-link @(currentAction == "Violations" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Violations">
                            <i class="fas fa-hand-paper me-2"></i>Vi phạm
                        </a>
                        <a class="nav-link @(currentAction == "Orders" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Orders">
                            <i class="fas fa-truck-fast me-2"></i>Đơn hàng
                        </a>
                        <a class="nav-link @(currentAction == "Reports" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Reports">
                            <i class="fas fa-chart-pie me-2"></i>Báo cáo
                        </a>
                        <hr class="mx-3 my-2" style="color: #ff6b6b; opacity: 0.2;">
                        <a class="nav-link @(currentAction == "Settings" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Settings">
                            <i class="fas fa-user-gear me-2"></i>Cài đặt
                        </a>
                    </nav>
                </div>
            </div>

            <main class="col-md-10">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
