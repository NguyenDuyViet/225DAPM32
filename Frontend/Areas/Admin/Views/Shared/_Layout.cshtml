<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Món Ngon Tại Nhà</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .admin-header {
            background: linear-gradient(135deg, #343a40 0%, #495057 100%);
        }
        .admin-sidebar {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 20px 0;
            min-height: calc(100vh - 120px);
        }
        .admin-sidebar .nav-link {
            color: #495057;
            padding: 12px 20px;
            margin: 5px 15px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .admin-sidebar .nav-link:hover {
            background: #e9ecef;
            color: #212529;
        }
        .admin-sidebar .nav-link.active {
            background: #007bff;
            color: white;
        }
    </style>
</head>
<body>
    <header class="admin-header bg-dark text-white py-3 mb-4">
        <div class="container-fluid">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h2 class="h4 mb-0">
                        <i class="fas fa-tachometer-alt me-3"></i>Admin Dashboard
                    </h2>
                </div>
                <div class="col-md-6 text-end">
                    <div class="d-flex align-items-center justify-content-end">
                        <div class="me-3">
                            <small class="opacity-75">Hôm nay</small>
                            <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-shield me-2"></i>Admin
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2">
                <div class="admin-sidebar shadow-sm">
                    <nav class="nav flex-column">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Index">
                            <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Restaurants" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Restaurants">
                            <i class="fas fa-utensils me-2"></i>Nhà hàng
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Users" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Users">
                            <i class="fas fa-users me-2"></i>Người dùng
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Policies" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Policies">
                            <i class="fas fa-shield-alt me-2"></i>Chính sách
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Violations" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Violations">
                            <i class="fas fa-exclamation-triangle me-2"></i>Vi phạm
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Orders" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Orders">
                            <i class="fas fa-shopping-cart me-2"></i>Đơn hàng
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Reports" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Reports">
                            <i class="fas fa-chart-bar me-2"></i>Báo cáo
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Settings" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Settings">
                            <i class="fas fa-chart-bar me-2"></i>Cài đặt
                        </a>
                    </nav>
                </div>
            </div>

            <main class="col-md-10">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>