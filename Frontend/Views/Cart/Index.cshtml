@model _225DAPM32.Models.CartResponse
@using _225DAPM32.Models

@{
    ViewData["Title"] = "Giỏ hàng";
    var user = ViewBag.User as User;
    var vouchers = ViewBag.Vouchers as List<Voucher> ?? new List<Voucher>();
    var restaurantName = Model.Items.FirstOrDefault()?.RestaurantName ?? "Nhà hàng";
    const decimal shippingFee = 15000m;

    string imageUrl(string? image) => string.IsNullOrWhiteSpace(image)
        ? "/images/placeholder-food.svg"
        : (image.StartsWith("http", StringComparison.OrdinalIgnoreCase) || image.StartsWith("/") ? image : "/" + image);
}

<main class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-8">
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Giỏ hàng của bạn</h1>
        <p class="text-sm text-gray-600">Kiểm tra món ăn và địa chỉ trước khi đặt hàng.</p>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="mb-5 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="mb-5 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">@error</div>
    }

    @if (!Model.Items.Any())
    {
        <section class="bg-white rounded-xl p-12 text-center shadow-sm border border-gray-100">
            <span class="material-symbols-outlined text-6xl text-gray-300">shopping_cart</span>
            <p class="text-lg font-semibold text-gray-800 mt-3">Giỏ hàng đang trống</p>
            <p class="text-sm text-gray-500 mb-6">Chọn nhà hàng để xem menu và thêm món.</p>
            <a asp-area="" asp-controller="Restaurants" asp-action="Index" class="inline-flex px-5 py-3 bg-orange-600 text-white rounded-lg font-medium hover:bg-orange-700">Xem nhà hàng</a>
        </section>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <div class="lg:col-span-8 space-y-6">
                <section class="bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100">
                    <div class="p-6 border-b border-gray-100 flex items-center gap-3">
                        <span class="material-symbols-outlined text-orange-600">restaurant</span>
                        <h2 class="text-lg font-semibold">@restaurantName</h2>
                    </div>
                    <div class="divide-y divide-gray-100">
                        @foreach (var item in Model.Items)
                        {
                            <div class="p-6 flex flex-col sm:flex-row items-start gap-4">
                                <img class="w-20 h-20 rounded-lg object-cover bg-gray-100" src="@imageUrl(item.FoodImage)" alt="@item.FoodName" onerror="this.onerror=null;this.src='/images/placeholder-food.svg';" />
                                <form asp-area="" asp-controller="Cart" asp-action="UpdateItem" method="post" class="flex-grow w-full">
                                    <input type="hidden" name="idCartFood" value="@item.IdCartFood" />
                                    <div class="flex justify-between gap-4">
                                        <h3 class="text-sm font-semibold text-gray-900">@item.FoodName</h3>
                                        <span class="text-sm font-semibold text-orange-600">@item.Total.ToString("N0")đ</span>
                                    </div>
                                    <p class="text-xs text-gray-500 mt-1">@item.Price.ToString("N0")đ / món</p>
                                    <div class="flex flex-wrap items-center gap-3 mt-4">
                                        <input type="number" name="quantity" min="1" value="@item.Quantity" class="w-20 border border-gray-300 rounded-lg px-3 py-2 text-sm" aria-label="Số lượng @item.FoodName" />
                                        <input type="text" name="note" value="@item.Note" placeholder="Ghi chú cho món" class="flex-grow min-w-40 border border-gray-300 rounded-lg px-3 py-2 text-sm" />
                                        <button type="submit" class="px-4 py-2 rounded-lg bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200">Cập nhật</button>
                                        <button type="submit" form="remove-@item.IdCartFood" class="text-red-600 text-sm font-medium hover:underline">Xóa</button>
                                    </div>
                                </form>
                                <form id="remove-@item.IdCartFood" asp-area="" asp-controller="Cart" asp-action="RemoveItem" method="post">
                                    <input type="hidden" name="idCartFood" value="@item.IdCartFood" />
                                </form>
                            </div>
                        }
                    </div>
                </section>
            </div>

            <div class="lg:col-span-4">
                <form asp-area="" asp-controller="Cart" asp-action="Checkout" method="post" class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 space-y-5">
                    <h2 class="text-lg font-semibold">Thông tin đặt hàng</h2>
                    <div>
                        <label for="phoneNumber" class="block text-sm font-medium text-gray-700 mb-2">Số điện thoại</label>
                        <input type="tel" id="phoneNumber" name="phoneNumber" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="Nhập số điện thoại" value="@(user?.Phone ?? string.Empty)" />
                    </div>
                    <div>
                        <label for="deliveryAddress" class="block text-sm font-medium text-gray-700 mb-2">Địa chỉ giao hàng</label>
                        <textarea id="deliveryAddress" name="deliveryAddress" required rows="3" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="Nhập địa chỉ nhận món">@(user?.Address ?? string.Empty)</textarea>
                    </div>
                    <div>
                        <label for="paymentMethod" class="block text-sm font-medium text-gray-700 mb-2">Phương thức thanh toán</label>
                        <select id="paymentMethod" name="paymentMethod" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                            <option value="cash">Tiền mặt khi nhận hàng</option>
                            <option value="card">Thẻ ATM / Visa</option>
                            <option value="momo">MoMo</option>
                        </select>
                    </div>
                    <div>
                        <label for="idVoucher" class="block text-sm font-medium text-gray-700 mb-2">Voucher</label>
                        <select id="idVoucher" name="idVoucher" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                            <option value="" data-value="0">Không sử dụng voucher</option>
                            @foreach (var voucher in vouchers)
                            {
                                <option value="@voucher.IdVoucher" data-value="@voucher.Value">
                                    @voucher.Code - giảm @voucher.Value.ToString("N0")đ (hạn @voucher.Expiry.ToString("dd/MM/yyyy"))
                                </option>
                            }
                        </select>
                        @if (!vouchers.Any())
                        {
                            <p class="mt-2 text-xs text-gray-500">Bạn chưa có voucher khả dụng.</p>
                        }
                    </div>
                    <div>
                        <label for="orderNote" class="block text-sm font-medium text-gray-700 mb-2">Ghi chú đơn hàng</label>
                        <textarea id="orderNote" name="note" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="Ghi chú giao hàng"></textarea>
                    </div>
                    <div class="border-t border-gray-100 pt-4 space-y-3 text-sm">
                        <div class="flex justify-between text-gray-600"><span>Tạm tính (@Model.TotalQuantity món)</span><span>@Model.TotalAmount.ToString("N0")đ</span></div>
                        <div class="flex justify-between text-gray-600"><span>Phí vận chuyển</span><span>@shippingFee.ToString("N0")đ</span></div>
                        <div class="flex justify-between text-green-700"><span>Voucher</span><span id="voucherDiscount">-0đ</span></div>
                        <div class="flex justify-between text-lg font-semibold pt-2"><span>Tổng cộng</span><span id="checkoutTotal" class="text-orange-600">@((Model.TotalAmount + shippingFee).ToString("N0"))đ</span></div>
                    </div>
                    <button type="submit" class="w-full bg-orange-600 text-white font-semibold py-3 rounded-xl hover:bg-orange-700">Đặt hàng ngay</button>
                </form>
            </div>
        </div>
    }
</main>

@if (Model.Items.Any())
{
    <script>
        (() => {
            const voucherSelect = document.getElementById("idVoucher");
            const discountOutput = document.getElementById("voucherDiscount");
            const totalOutput = document.getElementById("checkoutTotal");
            const foodAmount = @Model.TotalAmount.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const totalBeforeDiscount = @((Model.TotalAmount + shippingFee).ToString(System.Globalization.CultureInfo.InvariantCulture));
            const money = value => value.toLocaleString("vi-VN") + "đ";

            voucherSelect?.addEventListener("change", () => {
                const value = Number(voucherSelect.selectedOptions[0]?.dataset.value ?? 0);
                const discount = Math.min(value, foodAmount);
                discountOutput.textContent = "-" + money(discount);
                totalOutput.textContent = money(Math.max(0, totalBeforeDiscount - discount));
            });
        })();
    </script>
}
