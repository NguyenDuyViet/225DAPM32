@model _225DAPM32.Models.CartResponse
@{
    ViewData["Title"] = "Giỏ hàng";
    const decimal shippingFee = 15000m;
    var finalTotal = Model.TotalAmount + shippingFee;
    var user = ViewBag.User as _225DAPM32.Models.User;
    var deliveryAddress = user?.Address ?? "";
    string imageUrl(string? image) => string.IsNullOrWhiteSpace(image)
        ? "/images/placeholder-food.svg"
        : (image.StartsWith("http", StringComparison.OrdinalIgnoreCase) || image.StartsWith("/") ? image : "/" + image);
}

<main class="py-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="fw-bold">Giỏ hàng của bạn</h1>
            <p class="text-muted mb-0">Kiểm tra món ăn trước khi đặt hàng.</p>
        </div>
        <a asp-area="" asp-controller="Foods" asp-action="Index" class="btn btn-outline-primary">Tiếp tục chọn món</a>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="text-center py-5 bg-light rounded">
            <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">Giỏ hàng đang trống</h4>
            <a asp-area="" asp-controller="Foods" asp-action="Index" class="btn btn-primary mt-3">Chọn món ngay</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white fw-bold">Món đã chọn</div>
                    <div class="list-group list-group-flush">
                        @foreach (var item in Model.Items)
                        {
                            <div class="list-group-item p-4">
                                <div class="d-flex gap-3">
                                    <img src="@imageUrl(item.FoodImage)" alt="@item.FoodName" class="rounded" style="width: 96px; height: 96px; object-fit: cover;" onerror="this.onerror=null;this.src='/images/placeholder-food.svg';" />
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between gap-3">
                                            <div>
                                                <h5 class="fw-bold mb-1">@item.FoodName</h5>
                                                <p class="text-muted small mb-2">@item.Note</p>
                                                <div class="text-muted">@item.UnitPrice.ToString("N0")đ / phần</div>
                                            </div>
                                            <div class="text-end">
                                                <div class="fw-bold text-success mb-3">@item.TotalPrice.ToString("N0")đ</div>
                                                <form asp-area="" asp-controller="Cart" asp-action="RemoveItem" method="post">
                                                    <input type="hidden" name="idCartFood" value="@item.IdCartFood" />
                                                    <button class="btn btn-sm btn-outline-danger" type="submit">Xóa</button>
                                                </form>
                                            </div>
                                        </div>
                                        <form asp-area="" asp-controller="Cart" asp-action="UpdateItem" method="post" class="row g-2 mt-3">
                                            <input type="hidden" name="idCartFood" value="@item.IdCartFood" />
                                            <div class="col-sm-3">
                                                <input type="number" name="quantity" class="form-control" min="1" value="@item.Quantity" />
                                            </div>
                                            <div class="col-sm-6">
                                                <input type="text" name="note" class="form-control" value="@item.Note" placeholder="Ghi chú" />
                                            </div>
                                            <div class="col-sm-3">
                                                <button class="btn btn-outline-secondary w-100" type="submit">Cập nhật</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <form asp-area="" asp-controller="Cart" asp-action="Checkout" method="post" class="card border-0 shadow-sm sticky-top" style="top: 96px;">
                    <div class="card-body">
                        <h5 class="fw-bold mb-4">Tóm tắt đơn hàng</h5>
                        @if (string.IsNullOrWhiteSpace(deliveryAddress))
                        {
                            <div class="alert alert-warning">
                                Bạn chưa cập nhật vị trí giao hàng.
                                <a asp-area="" asp-controller="Profile" asp-action="Settings" class="alert-link">Cập nhật trong cài đặt</a>.
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Địa chỉ giao hàng</label>
                            <textarea name="deliveryAddress" class="form-control" rows="3" required placeholder="Nhập địa chỉ nhận hàng">@deliveryAddress</textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phương thức thanh toán</label>
                            <select name="paymentMethod" class="form-select">
                                <option value="cash">Tiền mặt</option>
                                <option value="card">Thẻ ATM / Visa</option>
                                <option value="momo">MoMo</option>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Ghi chú đơn hàng</label>
                            <input name="note" class="form-control" placeholder="Ghi chú cho nhà hàng" />
                        </div>
                        <div class="d-flex justify-content-between text-muted mb-2">
                            <span>Tạm tính (@Model.Items.Count món)</span>
                            <span>@Model.TotalAmount.ToString("N0")đ</span>
                        </div>
                        <div class="d-flex justify-content-between text-muted mb-3">
                            <span>Phí vận chuyển</span>
                            <span>@shippingFee.ToString("N0")đ</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="fw-bold">Tổng cộng</span>
                            <span class="fs-4 fw-bold text-orange-600">@finalTotal.ToString("N0")đ</span>
                        </div>
                        <button class="btn btn-success btn-lg w-100" type="submit" disabled="@(string.IsNullOrWhiteSpace(deliveryAddress))">Đặt hàng ngay</button>
                    </div>
                </form>
            </div>
        </div>
    }
</main>
