@{
    ViewData["Title"] = "Giỏ Hàng";
}

<main class="max-w-7xl mx-auto px-4 py-8">
    <!-- Page Title -->
    <div class="mb-8">
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Giỏ hàng của bạn</h1>
        <p class="text-sm text-gray-600">Kiểm tra lại món ăn và thanh toán để hoàn tất đơn hàng.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- Left Column: Items & Delivery -->
        <div class="lg:col-span-8 space-y-6">
            <!-- Delivery Section -->
            <section class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-orange-600">local_shipping</span>
                        <h2 class="text-lg font-semibold">Thông tin giao hàng</h2>
                    </div>
                    <button class="text-orange-600 text-sm font-medium hover:underline">Thay đổi</button>
                </div>
                <div class="flex gap-4 items-start p-4 bg-gray-50 rounded-lg border border-gray-200">
                    <span class="material-symbols-outlined text-gray-600 mt-1">location_on</span>
                    <div>
                        <p class="text-sm font-semibold">Nguyễn Văn A | 090 123 4567</p>
                        <p class="text-sm text-gray-600">99 Lê Lợi, Phường Bến Thành, Quận 1, TP. Hồ Chí Minh</p>
                    </div>
                </div>
            </section>

            <!-- Items Section -->
            <section class="bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100">
                <div class="p-6 border-b border-gray-100 flex items-center gap-3">
                    <span class="material-symbols-outlined text-orange-600">restaurant</span>
                    <h2 class="text-lg font-semibold">Phúc Long Tea & Coffee - Lê Lợi</h2>
                </div>
                <div class="divide-y divide-gray-100">
                    <!-- Item 1 -->
                    <div class="p-6 flex items-start gap-4">
                        <div class="w-20 h-20 rounded-lg overflow-hidden flex-shrink-0 bg-gray-100">
                            <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuABLVByC_OB6vVnCBsW_mpCOJvfsOg54SOrgxPf69O5m-hypWx-oAksZ_pw9dCvKTSQCY2uFLmF-JT2fKnfNv00awGxWuDnjxZfuCgKDJjJqQ-eC-bIUvgr0HMAFKk_ZPbglGxuqQhPffiA53kQ6-fjJFS3y73MGRh4JhhEsaNCq5R05Zk1q_sjGLpx0OK-W2QTciKCgcCBVyzP55NMASorTP13LLJSr1vrOiEAta0vKW9Qx0h8D1Ri1G3nrgpkDlsBSJMRppvUgIs" alt="Trà Sữa"/>
                        </div>
                        <div class="flex-grow">
                            <div class="flex justify-between items-start">
                                <h3 class="text-sm font-semibold text-gray-900">Trà Sữa Phúc Long (L)</h3>
                                <span class="text-sm font-semibold text-gray-900 item-total" data-price="55000">110.000đ</span>
                            </div>
                            <p class="text-sm text-gray-600 mb-4">Ít đá, 50% đường</p>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center border border-gray-300 rounded-full h-8 overflow-hidden">
                                    <button class="qty-decrease px-3 hover:bg-gray-100 transition-colors flex items-center justify-center">
                                        <span class="material-symbols-outlined text-sm">remove</span>
                                    </button>
                                    <span class="px-4 text-sm font-semibold qty-value">2</span>
                                    <button class="qty-increase px-3 hover:bg-gray-100 transition-colors flex items-center justify-center">
                                        <span class="material-symbols-outlined text-sm">add</span>
                                    </button>
                                </div>
                                <button class="text-gray-400 hover:text-red-600 transition-colors">
                                    <span class="material-symbols-outlined text-xl">delete</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Item 2 -->
                    <div class="p-6 flex items-start gap-4">
                        <div class="w-20 h-20 rounded-lg overflow-hidden flex-shrink-0 bg-gray-100">
                            <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDpgn4JB9dAN2Q9sU4VacbRBke8T-b0oNktdq30olY3BsV1AK7XbPflcEZCCRxuNrKYSRiH6qzIwobnlUdCflLk75f4T5qKCVZv59yrFxqvMqzI2XuqRPnHkhkHQohVis8IiLAjilWeR-3XnXPCStdtk26Ayfpvc44Gq8jfl4oNNFsOksBh1uaHZ8kq6jPPM3wYI0q9W5dtyePY-r_0k7ve1jdVyk83Lsf9KHQb4ON1st6ldwfnVM2leCmsd4gbhtDmdO4Ljg46bQs" alt="Bánh Mì"/>
                        </div>
                        <div class="flex-grow">
                            <div class="flex justify-between items-start">
                                <h3 class="text-sm font-semibold text-gray-900">Bánh Mì Phúc Long</h3>
                                <span class="text-sm font-semibold text-gray-900 item-total" data-price="35000">35.000đ</span>
                            </div>
                            <p class="text-sm text-gray-600 mb-4">Thêm chả, không cay</p>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center border border-gray-300 rounded-full h-8 overflow-hidden">
                                    <button class="qty-decrease px-3 hover:bg-gray-100 transition-colors flex items-center justify-center">
                                        <span class="material-symbols-outlined text-sm">remove</span>
                                    </button>
                                    <span class="px-4 text-sm font-semibold qty-value">1</span>
                                    <button class="qty-increase px-3 hover:bg-gray-100 transition-colors flex items-center justify-center">
                                        <span class="material-symbols-outlined text-sm">add</span>
                                    </button>
                                </div>
                                <button class="text-gray-400 hover:text-red-600 transition-colors">
                                    <span class="material-symbols-outlined text-xl">delete</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Payment Method Section -->
            <section class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="flex items-center gap-2 mb-6">
                    <span class="material-symbols-outlined text-orange-600">payments</span>
                    <h2 class="text-lg font-semibold">Phương thức thanh toán</h2>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <label class="payment-option flex items-center p-4 border-2 border-orange-600 bg-orange-50 rounded-xl cursor-pointer transition-colors">
                        <input checked class="payment-radio hidden" name="payment" type="radio" value="cash"/>
                        <span class="custom-radio mr-3"></span>
                        <span class="material-symbols-outlined text-orange-600 mr-3">payments</span>
                        <span class="text-sm font-semibold flex-grow">Tiền mặt</span>
                    </label>
                    <label class="payment-option flex items-center p-4 border border-gray-200 hover:border-orange-400 rounded-xl cursor-pointer transition-colors">
                        <input class="payment-radio hidden" name="payment" type="radio" value="card"/>
                        <span class="custom-radio mr-3"></span>
                        <span class="material-symbols-outlined text-gray-600 mr-3">credit_card</span>
                        <span class="text-sm font-semibold flex-grow">Thẻ ATM / Visa</span>
                    </label>
                    <label class="payment-option flex items-center p-4 border border-gray-200 hover:border-orange-400 rounded-xl cursor-pointer transition-colors">
                        <input class="payment-radio hidden" name="payment" type="radio" value="momo"/>
                        <span class="custom-radio mr-3"></span>
                        <span class="material-symbols-outlined text-gray-600 mr-3">wallet</span>
                        <span class="text-sm font-semibold flex-grow">MoMo</span>
                    </label>
                </div>
            </section>
        </div>

        <!-- Right Column: Summary -->
        <div class="lg:col-span-4">
            <div class="sticky top-24 space-y-4">
                <!-- Voucher Section -->
                <section class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-orange-600">confirmation_number</span>
                        <h2 class="text-sm font-semibold">Mã giảm giá</h2>
                    </div>
                    <div class="flex gap-2">
                        <input class="flex-grow border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-1 focus:ring-orange-500 focus:border-orange-500 outline-none" placeholder="Nhập mã ưu đãi..." type="text"/>
                        <button class="bg-orange-600 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-orange-700 transition-all active:scale-95">Áp dụng</button>
                    </div>
                    <div class="mt-4 p-2 bg-green-50 border border-green-200 rounded-lg flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-green-600 text-sm" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                            <span class="text-xs font-medium text-green-800">Giảm 15k phí vận chuyển</span>
                        </div>
                        <button class="text-xs font-bold text-green-600">Bỏ</button>
                    </div>
                </section>

                <!-- Total Section -->
                <section class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                    <h2 class="text-lg font-semibold mb-6">Tóm tắt đơn hàng</h2>
                    <div class="space-y-3 mb-6 border-b border-gray-100 pb-6">
                        <div class="flex justify-between text-sm text-gray-600">
                            <span>Tạm tính (3 món)</span>
                            <span>145.000đ</span>
                        </div>
                        <div class="flex justify-between text-sm text-gray-600">
                            <span>Phí vận chuyển (2.4km)</span>
                            <span>22.000đ</span>
                        </div>
                        <div class="flex justify-between text-sm text-green-600">
                            <span>Giảm giá vận chuyển</span>
                            <span>-15.000đ</span>
                        </div>
                        <div class="flex justify-between text-sm text-orange-600">
                            <span>Giảm giá món ăn</span>
                            <span>-20.000đ</span>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-8">
                        <span class="text-lg font-semibold">Tổng cộng</span>
                        <span class="text-2xl font-bold text-orange-600">132.000đ</span>
                    </div>
                    <button class="w-full bg-orange-600 text-white text-base font-semibold py-4 rounded-xl shadow-lg shadow-orange-200 hover:bg-orange-700 transition-all transform active:scale-[0.98] flex items-center justify-center gap-2">
                        <span>ĐẶT HÀNG NGAY</span>
                        <span class="material-symbols-outlined">arrow_forward</span>
                    </button>
                    <p class="text-[11px] text-center text-gray-500 mt-4">Bằng việc nhấn đặt hàng, bạn đồng ý với các Điều khoản & Chính sách của chúng tôi.</p>
                </section>
            </div>
        </div>
    </div>
</main>

<style>
    /* Custom Radio Button */
    .custom-radio {
        width: 20px;
        height: 20px;
        border: 2px solid #d1d5db;
        border-radius: 50%;
        position: relative;
        flex-shrink: 0;
        transition: all 0.2s ease;
    }
    
    .payment-option:hover .custom-radio {
        border-color: #fb923c;
    }
    
    .payment-radio:checked + .custom-radio {
        border-color: #ea580c;
        background-color: #fff;
    }
    
    .payment-radio:checked + .custom-radio::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 10px;
        height: 10px;
        background-color: #ea580c;
        border-radius: 50%;
    }
</style>

<script>
    // Payment method selection
    document.addEventListener('DOMContentLoaded', function() {
        const paymentRadios = document.querySelectorAll('.payment-radio');
        
        paymentRadios.forEach(radio => {
            radio.addEventListener('change', function() {
                // Reset all payment options
                document.querySelectorAll('.payment-option').forEach(option => {
                    option.classList.remove('border-orange-600', 'bg-orange-50', 'border-2');
                    option.classList.add('border', 'border-gray-200');
                    
                    // Reset icon colors
                    const icon = option.querySelector('.material-symbols-outlined');
                    if (icon) {
                        icon.classList.remove('text-orange-600');
                        icon.classList.add('text-gray-600');
                    }
                });
                
                // Highlight selected option
                const selectedOption = this.closest('.payment-option');
                selectedOption.classList.remove('border', 'border-gray-200');
                selectedOption.classList.add('border-2', 'border-orange-600', 'bg-orange-50');
                
                // Update icon color
                const icon = selectedOption.querySelector('.material-symbols-outlined');
                if (icon) {
                    icon.classList.remove('text-gray-600');
                    icon.classList.add('text-orange-600');
                }
            });
        });

        // Quantity controls
        const decreaseButtons = document.querySelectorAll('.qty-decrease');
        const increaseButtons = document.querySelectorAll('.qty-increase');

        // Format number to Vietnamese currency
        function formatCurrency(amount) {
            return new Intl.NumberFormat('vi-VN').format(amount) + 'đ';
        }

        // Update item total and cart summary
        function updateTotals() {
            let subtotal = 0;
            
            // Calculate subtotal from all items
            document.querySelectorAll('.qty-value').forEach(qtyElement => {
                const itemContainer = qtyElement.closest('.p-6');
                const itemTotal = itemContainer.querySelector('.item-total');
                const price = parseInt(itemTotal.dataset.price);
                const qty = parseInt(qtyElement.textContent);
                subtotal += price * qty;
            });

            // Update subtotal display
            const subtotalElement = document.querySelector('.space-y-3 .flex:first-child span:last-child');
            if (subtotalElement) {
                subtotalElement.textContent = formatCurrency(subtotal);
            }

            // Calculate total (subtotal + shipping - discounts)
            const shipping = 22000;
            const shippingDiscount = 15000;
            const foodDiscount = 20000;
            const total = subtotal + shipping - shippingDiscount - foodDiscount;

            // Update total display
            const totalElement = document.querySelector('.text-2xl.font-bold.text-orange-600');
            if (totalElement) {
                totalElement.textContent = formatCurrency(total);
            }

            // Update item count
            let totalItems = 0;
            document.querySelectorAll('.qty-value').forEach(qtyElement => {
                totalItems += parseInt(qtyElement.textContent);
            });
            const itemCountElement = document.querySelector('.space-y-3 .flex:first-child span:first-child');
            if (itemCountElement) {
                itemCountElement.textContent = `Tạm tính (${totalItems} món)`;
            }
        }

        // Decrease quantity
        decreaseButtons.forEach(button => {
            button.addEventListener('click', function() {
                const qtyElement = this.parentElement.querySelector('.qty-value');
                const itemTotal = this.closest('.p-6').querySelector('.item-total');
                const price = parseInt(itemTotal.dataset.price);
                let qty = parseInt(qtyElement.textContent);
                
                if (qty > 1) {
                    qty--;
                    qtyElement.textContent = qty;
                    itemTotal.textContent = formatCurrency(price * qty);
                    updateTotals();
                }
            });
        });

        // Increase quantity
        increaseButtons.forEach(button => {
            button.addEventListener('click', function() {
                const qtyElement = this.parentElement.querySelector('.qty-value');
                const itemTotal = this.closest('.p-6').querySelector('.item-total');
                const price = parseInt(itemTotal.dataset.price);
                let qty = parseInt(qtyElement.textContent);
                
                qty++;
                qtyElement.textContent = qty;
                itemTotal.textContent = formatCurrency(price * qty);
                updateTotals();
            });
        });
    });
</script>
