@model IEnumerable<_225DAPM32.Models.Restaurant>

@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 0;
    int totalItems = ViewBag.TotalItems ?? 0;
    int? selectedCategoryId = ViewBag.SelectedCategoryId;
}

<!-- Sort Bar -->
<div class="bg-white rounded-lg p-4 mb-6 shadow-sm flex items-center justify-between">
    <div class="flex items-center gap-3">
        <span class="text-gray-600 text-sm">Sắp xếp theo:</span>
        <button class="px-4 py-2 bg-orange-600 text-white rounded-full text-sm font-medium shadow-md">
            Liên quan
        </button>
        <button class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
            Gần đây
        </button>
        <button class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
            Bán chạy
        </button>
        <button class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
            Giá thấp
        </button>
    </div>
    <div class="text-sm text-gray-600">
        <span class="font-bold text-gray-900">@totalItems</span> kết quả
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-20">
        <span class="material-symbols-outlined text-6xl text-gray-300 mb-4">store</span>
        <p class="text-gray-500 text-lg">Chưa có nhà hàng nào</p>
        <p class="text-gray-400 text-sm mt-2">Vui lòng quay lại sau</p>
    </div>
}
else
{
    <!-- Restaurant Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        @foreach (var restaurant in Model)
        {
            <div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 cursor-pointer hover:-translate-y-1">
                <div class="relative">
                    <img src="@restaurant.Image" alt="@restaurant.NameRestaurant" class="w-full h-48 object-cover" />
                    <div class="absolute bottom-2 right-2 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-md flex items-center gap-1">
                        <span class="material-symbols-outlined text-gray-700 text-sm">schedule</span>
                        <span class="text-xs font-semibold text-gray-700">
                            @restaurant.OpenTime.ToString(@"hh\:mm") - @restaurant.CloseTime.ToString(@"hh\:mm")
                        </span>
                    </div>
                </div>
                <div class="p-4">
                    <h3 class="font-semibold text-gray-900 mb-2 truncate">@restaurant.NameRestaurant</h3>
                    <div class="flex items-center gap-2 text-sm text-gray-600 mb-3">
                        <div class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-orange-600 text-base">location_on</span>
                            <span class="truncate">@restaurant.Address</span>
                        </div>
                    </div>
                    <p class="text-sm text-gray-500 mb-3 line-clamp-2">@restaurant.Description</p>
                    <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                        <div class="flex items-center gap-1 text-sm text-gray-500">
                            <span class="material-symbols-outlined text-base">schedule</span>
                            <span>@restaurant.OpenTime.ToString(@"hh\:mm") - @restaurant.CloseTime.ToString(@"hh\:mm")</span>
                        </div>
                        <a href="@Url.Action("Details", "Restaurants", new { area = "", id = restaurant.IdRestaurant })" class="px-4 py-2 rounded-md bg-orange-600 text-white text-sm font-medium hover:bg-orange-700 transition-colors">
                            Xem menu
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (totalPages >= 1)
    {
        <div class="mt-8 flex justify-center items-center gap-2">
            @if (currentPage > 1)
            {
                <a href="javascript:void(0)" onclick="loadRestaurants(@(currentPage - 1), @(selectedCategoryId.HasValue ? selectedCategoryId.Value.ToString() : "null"))"
                   class="w-9 h-9 rounded-md border border-gray-300 flex items-center justify-center hover:bg-gray-50 transition-colors">
                    <span class="material-symbols-outlined text-gray-600">chevron_left</span>
                </a>
            }
            else
            {
                <span class="w-9 h-9 rounded-md border border-gray-200 flex items-center justify-center opacity-50 cursor-not-allowed">
                    <span class="material-symbols-outlined text-gray-400">chevron_left</span>
                </span>
            }

            @{
                int startPage = Math.Max(1, currentPage - 2);
                int endPage = Math.Min(totalPages, currentPage + 2);

                if (startPage > 1)
                {
                    <a href="javascript:void(0)" onclick="loadRestaurants(1, @(selectedCategoryId.HasValue ? selectedCategoryId.Value.ToString() : "null"))"
                       class="w-9 h-9 rounded-md border border-gray-300 flex items-center justify-center hover:bg-gray-50 transition-colors text-gray-700">
                        1
                    </a>
                    if (startPage > 2)
                    {
                        <span class="text-gray-500">...</span>
                    }
                }

                for (int i = startPage; i <= endPage; i++)
                {
                    if (i == currentPage)
                    {
                        <span class="w-9 h-9 rounded-md bg-orange-600 text-white font-semibold flex items-center justify-center">
                            @i
                        </span>
                    }
                    else
                    {
                        <a href="javascript:void(0)" onclick="loadRestaurants(@i, @(selectedCategoryId.HasValue ? selectedCategoryId.Value.ToString() : "null"))"
                           class="w-9 h-9 rounded-md border border-gray-300 flex items-center justify-center hover:bg-gray-50 transition-colors text-gray-700">
                            @i
                        </a>
                    }
                }

                if (endPage < totalPages)
                {
                    if (endPage < totalPages - 1)
                    {
                        <span class="text-gray-500">...</span>
                    }
                    <a href="javascript:void(0)" onclick="loadRestaurants(@totalPages, @(selectedCategoryId.HasValue ? selectedCategoryId.Value.ToString() : "null"))"
                       class="w-9 h-9 rounded-md border border-gray-300 flex items-center justify-center hover:bg-gray-50 transition-colors text-gray-700">
                        @totalPages
                    </a>
                }
            }

            @if (currentPage < totalPages)
            {
                <a href="javascript:void(0)" onclick="loadRestaurants(@(currentPage + 1), @(selectedCategoryId.HasValue ? selectedCategoryId.Value.ToString() : "null"))"
                   class="w-9 h-9 rounded-md border border-gray-300 flex items-center justify-center hover:bg-gray-50 transition-colors">
                    <span class="material-symbols-outlined text-gray-600">chevron_right</span>
                </a>
            }
            else
            {
                <span class="w-9 h-9 rounded-md border border-gray-200 flex items-center justify-center opacity-50 cursor-not-allowed">
                    <span class="material-symbols-outlined text-gray-400">chevron_right</span>
                </span>
            }
        </div>

        <div class="mt-3 text-center text-sm text-gray-500">
            Trang @currentPage / @totalPages
        </div>
    }
}
