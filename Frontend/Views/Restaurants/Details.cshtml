<main class="max-w-7xl mx-auto px-4 py-2">
    <!-- Restaurant Header Section -->
    <section class="bg-white rounded-xl overflow-hidden shadow-sm mb-5">
        <div class="relative h-[300px] w-full">
            <img alt="Restaurant Cover" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAVuZTCkpkJj2a3ZhCGQMFAAtXqlMXXue80K_R4qQ2I78hY6y-K3qxybUWmlW1GFzPs-0cZGm2Ru_j5cwXmJ_mFLLghH6f4EVugDpWUEkYqqXsmxAeJyn4fQYEULaFOv3xMsb_mIImStCVCazpNSBntteLVVygWLP-nzSCJbtLLLufe-n7d5xkoSuZjucGzFaj2bIR-H2ZdJ6Q8XaMlX0R8q5qvXMvpZPydqIF-3kc38f10Dz1dsmCEHqzkHEMUN5gVbulPbs6U6Xc"/>
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 text-white">
                <div class="flex items-center gap-2 mb-2">
                    <span class="bg-orange-600 text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">Đối tác Món ngon tại nhà</span>
                    <div class="flex items-center bg-yellow-400 text-black px-2 py-0.5 rounded text-[10px] font-bold">
                        <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">star</span>4.8 (500+)
                    </div>
                </div>
                <h1 class="text-white text-3xl md:text-4xl font-bold mb-2">Bếp Việt Heritage - Phan Xích Long</h1>
                <div class="flex flex-wrap items-center gap-4 text-white/90 text-sm">
                    <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[18px]">location_on</span>
                        125 Phan Xích Long, P. 2, Q. Phú Nhuận, TP. HCM
                    </div>
                    <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[18px]">payments</span>
                        35,000đ - 150,000đ
                    </div>
                    <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[18px]">schedule</span>
                        Mở cửa: 07:00 - 22:00
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="flex flex-col lg:flex-row gap-5 items-start">
        <!-- Menu Section -->
        <div class="flex-1 w-full">
            <!-- Category Tabs -->
            <div class="bg-white mb-5 rounded-xl shadow-sm border border-gray-100 flex overflow-x-auto p-1">
