@model _225DAPM32.Models.Restaurant

@{
    ViewData["Title"] = Model.NameRestaurant;
    var foods = ViewBag.Foods as List<_225DAPM32.Models.Food> ?? new List<_225DAPM32.Models.Food>();
}

<main class="max-w-7xl mx-auto px-4 py-2">
    <!-- Restaurant Header Section -->
    <section class="bg-white rounded-xl overflow-hidden shadow-sm mb-5">
        <div class="relative h-[300px] w-full">
            <img alt="@Model.NameRestaurant" class="w-full h-full object-cover" src="@Model.Image" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 text-white">
                <div class="flex items-center gap-2 mb-2">
                    <span class="bg-orange-600 text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">Đối tác Món ngon tại nhà</span>
                </div>
                <h1 class="text-white text-3xl md:text-4xl font-bold mb-2">@Model.NameRestaurant</h1>
                <div class="flex flex-wrap items-center gap-4 text-white/90 text-sm">
                    <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[18px]">location_on</span>
                        @Model.Address
                    </div>
                    <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[18px]">schedule</span>
                        Mở cửa: @Model.OpenTime.ToString(@"hh\:mm") - @Model.CloseTime.ToString(@"hh\:mm")
                    </div>
                    <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[18px]">restaurant_menu</span>
                        @foods.Count món
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="flex flex-col lg:flex-row gap-5 items-start">
        <!-- Menu Section -->
        <div class="flex-1 w-full">
            <!-- Category Tabs -->
            <div class="bg-white mb-5 rounded-xl shadow-sm border border-gray-100 flex overflow-x-auto p-1">
                <button onclick="switchTab('food')" id="tab-food"
                        class="px-6 py-3 text-sm font-semibold text-orange-600 border-b-2 border-orange-600 transition-colors whitespace-nowrap">
                    Đồ ăn
                </button>
                <button onclick="switchTab('drink')" id="tab-drink"
                        class="px-6 py-3 text-sm font-semibold text-gray-500 hover:text-orange-600 transition-colors whitespace-nowrap">
                    Thức uống
                </button>
                <button onclick="switchTab('combo')" id="tab-combo"
                        class="px-6 py-3 text-sm font-semibold text-gray-500 hover:text-orange-600 transition-colors whitespace-nowrap">
                    Combo món ăn
                </button>
            </div>

            <!-- Tab: Đồ ăn -->
            <div id="content-food" class="tab-content space-y-3">
                @if (!foods.Any())
                {
                    <div class="text-center py-10 text-gray-400">
                        <span class="material-symbols-outlined text-5xl mb-2">restaurant</span>
                        <p>Chưa có món ăn nào</p>
                    </div>
                }
                else
                {
                    @foreach (var food in foods)
                    {
                        @await Html.PartialAsync("_FoodCard", food)
                    }
                }
            </div>

            <!-- Tab: Thức uống -->
            <div id="content-drink" class="tab-content hidden space-y-3">
                <div class="text-center py-10 text-gray-400">
                    <span class="material-symbols-outlined text-5xl mb-2">local_cafe</span>
                    <p>Chưa có thức uống nào</p>
                </div>
            </div>

            <!-- Tab: Combo món ăn -->
            <div id="content-combo" class="tab-content hidden space-y-3">
                <div class="text-center py-10 text-gray-400">
                    <span class="material-symbols-outlined text-5xl mb-2">local_offer</span>
                    <p>Chưa có combo nào</p>
                </div>
            </div>

            <!-- Nút quay lại -->
            <div class="mt-6">
                <a href="@Url.Action("Index", "Restaurants", new { area = "" })" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors font-medium text-sm">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Quay lại danh sách
                </a>
            </div>
        </div>

        <!-- Sidebar -->
        <aside class="w-full lg:w-[320px] sticky top-16 z-30">
            <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden">
                <div class="bg-orange-600 p-4 flex items-center gap-2 text-white">
                    <span class="material-symbols-outlined">store</span>
                    <span class="text-sm font-semibold">Thông tin nhà hàng</span>
                </div>
                <div class="p-4 space-y-4">
                    <div class="flex items-center gap-3">
                        <img src="@Model.Image" alt="@Model.NameRestaurant" class="w-16 h-16 rounded-lg object-cover" />
                        <div>
                            <h3 class="font-semibold text-gray-800">@Model.NameRestaurant</h3>
                            <p class="text-xs text-gray-500 mt-1">@Model.Address</p>
                        </div>
                    </div>
                    <div class="border-t border-gray-100 pt-3 space-y-2">
                        <div class="flex items-center gap-2 text-sm text-gray-600">
                            <span class="material-symbols-outlined text-orange-600 text-base">schedule</span>
                            <span>@Model.OpenTime.ToString(@"hh\:mm") - @Model.CloseTime.ToString(@"hh\:mm")</span>
                        </div>
                        <div class="flex items-center gap-2 text-sm text-gray-600">
                            <span class="material-symbols-outlined text-orange-600 text-base">location_on</span>
                            <span>@Model.Address</span>
                        </div>
                        <div class="flex items-center gap-2 text-sm text-gray-600">
                            <span class="material-symbols-outlined text-orange-600 text-base">restaurant_menu</span>
                            <span>@foods.Count món ăn</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mô tả nhà hàng -->
            <div class="mt-4 bg-white rounded-xl shadow-sm border border-gray-100 p-4">
                <h3 class="font-semibold text-gray-800 mb-2">Giới thiệu</h3>
                <p class="text-sm text-gray-600 leading-relaxed">@Model.Description</p>
            </div>
        </aside>
    </div>
</main>

<style>
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
</style>

<script>
function switchTab(tabName) {
    // Ẩn tất cả tab content
    const allContents = document.querySelectorAll('.tab-content');
    allContents.forEach(content => content.classList.add('hidden'));

    // Xóa active state của tất cả tab buttons
    const allTabs = document.querySelectorAll('[id^="tab-"]');
    allTabs.forEach(tab => {
        tab.classList.remove('text-orange-600', 'border-b-2', 'border-orange-600');
        tab.classList.add('text-gray-500');
    });

    // Hiển thị tab content được chọn
    const selectedContent = document.getElementById('content-' + tabName);
    if (selectedContent) {
        selectedContent.classList.remove('hidden');
    }

    // Active tab button được chọn
    const selectedTab = document.getElementById('tab-' + tabName);
    if (selectedTab) {
        selectedTab.classList.remove('text-gray-500');
        selectedTab.classList.add('text-orange-600', 'border-b-2', 'border-orange-600');
    }
}
</script>
