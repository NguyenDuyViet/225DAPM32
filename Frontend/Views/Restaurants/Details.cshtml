                            </div>
                        </div>
                        <button class="text-gray-300 hover:text-red-500">
                            <span class="material-symbols-outlined text-[18px]">close</span>
                        </button>
                    </div>
                    <!-- Cart Item 2 -->
                    <div class="flex items-start gap-3 border-b border-gray-100 pb-3">
                        <div class="flex-1">
                            <h4 class="text-sm font-semibold text-gray-800 line-clamp-1">Cà Phê Sữa Đá Sài Gòn</h4>
                            <p class="text-[12px] text-gray-500">Ít ngọt</p>
                            <div class="flex items-center gap-4 mt-2">
                                <div class="flex items-center border border-gray-200 rounded-lg h-7">
                                    <button class="px-2 text-gray-400 hover:text-orange-600">-</button>
                                    <span class="px-2 text-[13px] font-bold">1</span>
                                    <button class="px-2 text-gray-400 hover:text-orange-600">+</button>
                                </div>
                                <span class="font-bold text-gray-700 text-sm">29,000đ</span>
                            </div>
                        </div>
                        <button class="text-gray-300 hover:text-red-500">
                            <span class="material-symbols-outlined text-[18px]">close</span>
                        </button>
                    </div>
                    <!-- Bill Summary -->
                    <div class="space-y-2 pt-2 text-sm text-gray-600">
                        <div class="flex justify-between">
                            <span>Tạm tính</span>
                            <span>94,000đ</span>
                        </div>
                        <div class="flex justify-between">
                            <span>Phí dịch vụ</span>
                            <span>5,000đ</span>
                        </div>
                        <div class="flex justify-between">
                            <span>Phí giao hàng (2.5km)</span>
                            <span class="text-orange-600 font-bold">Miễn phí</span>
                        </div>
                        <div class="flex justify-between text-base font-bold text-gray-800 pt-2 border-t border-dashed border-gray-200">
                            <span>Tổng cộng</span>
                            <span class="text-orange-600 text-lg">99,000đ</span>
                        </div>
                    </div>
                    <button class="w-full bg-orange-600 text-white py-3 rounded-xl text-sm font-semibold active:scale-[0.98] transition-transform shadow-lg shadow-orange-200">
                        Thanh toán ngay
                    </button>
                    <p class="text-center text-[11px] text-gray-400">
                        Bằng cách đặt hàng, bạn đồng ý với <a class="underline" href="#">Điều khoản dịch vụ</a>
                    </p>
                </div>
            </div>
            <!-- Promotional Banner in Sidebar -->
            <div class="mt-4 bg-orange-50 border border-orange-100 rounded-xl p-4 flex items-center gap-3">
                <span class="material-symbols-outlined text-orange-600">confirmation_number</span>
                <div>
                    <p class="text-[12px] font-bold text-orange-800 uppercase tracking-wide">Nhập mã: FOODLOVER</p>
                    <p class="text-[11px] text-orange-700">Giảm ngay 25k cho đơn hàng từ 150k</p>
                </div>
            </div>
        </aside>
    </div>
</main>

<style>
.line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
</style>

<script>
function switchTab(tabName) {
    // Ẩn tất cả tab content
    const allContents = document.querySelectorAll('.tab-content');
    allContents.forEach(content => {
        content.classList.add('hidden');
    });
    
    // Xóa active state của tất cả tab buttons
    const allTabs = document.querySelectorAll('[id^="tab-"]');
    allTabs.forEach(tab => {
        tab.classList.remove('text-orange-600', 'border-b-2', 'border-orange-600');
        tab.classList.add('text-gray-500');
    });
    
    // Hiển thị tab content được chọn
    const selectedContent = document.getElementById('content-' + tabName);
    if (selectedContent) {
        selectedContent.classList.remove('hidden');
    }
    
    // Active tab button được chọn
    const selectedTab = document.getElementById('tab-' + tabName);
    if (selectedTab) {
        selectedTab.classList.remove('text-gray-500');
        selectedTab.classList.add('text-orange-600', 'border-b-2', 'border-orange-600');
    }
}
</script>
