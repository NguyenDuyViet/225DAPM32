@model _225DAPM32.Models.Restaurant

@{
    ViewData["Title"] = "Chi Tiết Nhà Hàng";
}

<h1>@Model.Name_Restaurant</h1>

<div class="row">
    <div class="col-md-6">
        <img src="@Model.Image" class="img-fluid" alt="@Model.Name_Restaurant">
    </div>
    <div class="col-md-6">
        <h3>Mô tả</h3>
        <p>@Model.Description</p>
        <h4>Địa chỉ: @Model.Address</h4>
        <p><strong>Giờ mở cửa:</strong> @Model.OpenTime.ToString(@"hh\:mm") - @Model.CloseTime.ToString(@"hh\:mm")</p>
        <a href="@Url.Action("Menu", "Restaurants", new { id = Model.Id_Restaurant })" class="btn btn-success me-2">
            <i class="fas fa-utensils me-1"></i>Xem Menu
        </a>
        <a href="@Url.Action("Index", "Restaurants")" class="btn btn-secondary">Quay lại</a>
    </div>
</div>