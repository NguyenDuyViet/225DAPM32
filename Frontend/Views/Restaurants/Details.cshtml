                <button onclick="switchTab('dessert')" id="tab-dessert" class="px-6 py-3 text-sm font-semibold text-gray-500 hover:text-orange-600 transition-colors whitespace-nowrap">Tráng miệng</button>
                <button onclick="switchTab('combo')" id="tab-combo" class="px-6 py-3 text-sm font-semibold text-gray-500 hover:text-orange-600 transition-colors whitespace-nowrap">Combo ưu đãi</button>
            </div>

            <!-- Menu Items Group: Món chính -->
            <div id="content-main" class="tab-content space-y-5">
                <h2 class="text-xl md:text-2xl font-bold text-gray-800 mb-4 px-2 border-l-4 border-orange-600">Món chính</h2>
                <div class="space-y-3">
                    @foreach (var food in mockFoods.Where(f => f.Category == "main"))
                    {
                        <!-- Food Card -->
                        <div class="bg-white p-3 rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-50 flex gap-4 group">
                            <div class="w-24 h-24 flex-shrink-0 rounded-lg overflow-hidden relative">
                                <img alt="@food.Name" class="w-full h-full object-cover" src="@food.Image"/>
                                @if (!string.IsNullOrEmpty(food.Badge))
                                {
                                    <div class="absolute top-1 left-1 bg-red-600 text-white text-[10px] font-bold px-1.5 py-0.5 rounded">@food.Badge</div>
                                }
                            </div>
                            <div class="flex flex-col justify-between flex-1">
                                <div>
                                    <h3 class="text-base md:text-lg font-semibold text-gray-800 line-clamp-1">@food.Name</h3>
                                    <p class="text-sm text-gray-500 line-clamp-2 mt-1">@food.Description</p>
                                </div>
                                <div class="flex items-center justify-between mt-2">
                                    <div class="flex flex-col">
                                        <span class="font-bold text-orange-600 text-base">@food.Price</span>
                                        @if (!string.IsNullOrEmpty(food.OldPrice))
                                        {
                                            <span class="text-gray-400 line-through text-[12px]">@food.OldPrice</span>
                                        }
                                    </div>
                                    <button class="w-8 h-8 rounded-full bg-orange-600 text-white flex items-center justify-center active:scale-90 transition-transform shadow-sm">
                                        <span class="material-symbols-outlined text-[20px]">add</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Menu Items Group: Đồ uống -->
            <div id="content-drink" class="tab-content hidden space-y-5">
                <h2 class="text-xl md:text-2xl font-bold text-gray-800 mb-4 px-2 border-l-4 border-orange-600">Đồ uống</h2>
                <div class="space-y-3">
                    @foreach (var food in mockFoods.Where(f => f.Category == "drink"))
                    {
                        <div class="bg-white p-3 rounded-xl shadow-sm border border-gray-50 flex gap-4 group">
                            <div class="w-24 h-24 flex-shrink-0 rounded-lg overflow-hidden relative">
                                <img alt="@food.Name" class="w-full h-full object-cover" src="@food.Image"/>
                            </div>
                            <div class="flex flex-col justify-between flex-1">
                                <div>
                                    <h3 class="text-base font-semibold text-gray-800">@food.Name</h3>
                                    <p class="text-sm text-gray-500 line-clamp-2 mt-1">@food.Description</p>
                                </div>
                                <div class="flex items-center justify-between mt-2">
                                    <span class="font-bold text-orange-600 text-base">@food.Price</span>
                                    <button class="w-8 h-8 rounded-full bg-orange-600 text-white flex items-center justify-center active:scale-90 transition-transform shadow-sm">
                                        <span class="material-symbols-outlined text-[20px]">add</span>
                                    </button>
                                </div>
                            </div>
                        </div>
