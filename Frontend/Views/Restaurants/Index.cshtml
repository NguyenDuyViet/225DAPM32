        new { Name = "Sushi Hokkaido Sachi", Image = "https://lh3.googleusercontent.com/aida-public/AB6AXuDohJ5zrkhgFTvkjk_obz4LFXHKKyjzYMRyOPGREopYp57a7VOnJ2N6ht0iCjxtS71Gvf_CmC4JpQEHLDaMX17bqhs7OQLv2bZllUfR7Z0lhHw6OvFmZxTNXSIv0As59bj6_dMVVVTGRLEPLJQ1YfWI3l0EsOv7Vyqa1-b5eELxxgvk6HwQaggcftz0A0RSVAWYhOK6ZbwsV5WdlMRNlu2dLn03MWM1a-bSXr_79sZLaYkq_uWAB0hqSDEcqJZsxXXC0Mbmm4CWlBA", Rating = "4.9", Reviews = "800+", Distance = "3.2 km", Price = "120.000đ", Badge = "Freeship" },
