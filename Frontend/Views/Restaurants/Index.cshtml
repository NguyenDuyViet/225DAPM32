<div class="bg-gray-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 py-6">
        <div class="flex gap-6">
            <!-- Sidebar Filters -->
            <aside class="w-64 flex-shrink-0">
                <!-- Khu vực -->
                <div class="bg-white rounded-lg p-4 mb-4 shadow-sm">
                    <h3 class="flex items-center gap-2 text-gray-700 font-semibold mb-3">
                        <span class="material-symbols-outlined text-orange-600">location_on</span>
                        Khu vực
                    </h3>
                    <div class="space-y-2">
                        <label class="flex items-center gap-2 cursor-pointer hover:text-orange-600 transition-colors">
                            <input type="checkbox" checked class="w-4 h-4 text-orange-600 rounded border-gray-300 focus:ring-orange-500" />
                            <span class="text-sm text-gray-700">Quận 1</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer hover:text-orange-600 transition-colors">
                            <input type="checkbox" class="w-4 h-4 text-orange-600 rounded border-gray-300 focus:ring-orange-500" />
                            <span class="text-sm text-gray-700">Quận 3</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer hover:text-orange-600 transition-colors">
                            <input type="checkbox" class="w-4 h-4 text-orange-600 rounded border-gray-300 focus:ring-orange-500" />
                            <span class="text-sm text-gray-700">Quận Bình Thạnh</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer hover:text-orange-600 transition-colors">
                            <input type="checkbox" class="w-4 h-4 text-orange-600 rounded border-gray-300 focus:ring-orange-500" />
                            <span class="text-sm text-gray-700">Quận 7</span>
                        </label>
                    </div>
                </div>

                <!-- Phân loại -->
                <div class="bg-white rounded-lg p-4 mb-4 shadow-sm">
                    <h3 class="flex items-center gap-2 text-gray-700 font-semibold mb-3">
                        <span class="material-symbols-outlined text-orange-600">restaurant</span>
                        Phân loại
                    </h3>
                    <div class="space-y-1">
                        <button class="w-full text-left px-3 py-2 rounded-md bg-orange-600 text-white font-medium text-sm">
                            Tất cả
                        </button>
                        <button class="w-full text-left px-3 py-2 rounded-md hover:bg-gray-100 text-gray-700 text-sm transition-colors">
                            Cơm trưa
                        </button>
                        <button class="w-full text-left px-3 py-2 rounded-md hover:bg-gray-100 text-gray-700 text-sm transition-colors">
                            Trà sữa & Cà phê
                        </button>
                        <button class="w-full text-left px-3 py-2 rounded-md hover:bg-gray-100 text-gray-700 text-sm transition-colors">
                            Bún/Phở/Mì
                        </button>
                        <button class="w-full text-left px-3 py-2 rounded-md hover:bg-gray-100 text-gray-700 text-sm transition-colors">
                            Ăn vặt
                        </button>
                        <button class="w-full text-left px-3 py-2 rounded-md hover:bg-gray-100 text-gray-700 text-sm transition-colors">
                            Pizza/Fastfood
                        </button>
                    </div>
                </div>

                <!-- Giá cả -->
                <div class="bg-white rounded-lg p-4 shadow-sm">
                    <h3 class="flex items-center gap-2 text-gray-700 font-semibold mb-3">
                        <span class="material-symbols-outlined text-orange-600">payments</span>
                        Giá cả
                    </h3>
                    <div class="space-y-3">
                        <div class="flex gap-2">
                            <input type="text" placeholder="Từ" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" />
                            <input type="text" placeholder="Đến" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" />
                        </div>
                        <button class="w-full py-2 bg-orange-600 text-white rounded-md font-medium text-sm hover:bg-orange-700 transition-colors">
                            Áp dụng
                        </button>
                    </div>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="flex-1">
                <!-- Sort Bar -->
                <div class="bg-white rounded-lg p-4 mb-6 shadow-sm flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <span class="text-gray-600 text-sm">Sắp xếp theo:</span>
                        <button class="px-4 py-2 bg-orange-600 text-white rounded-full text-sm font-medium shadow-md">
                            Liên quan
                        </button>
                        <button class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
                            Gần đây
                        </button>
                        <button class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
                            Bán chạy
                        </button>
                        <button class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
                            Giá thấp
                        </button>
                    </div>
                    <div class="text-sm text-gray-600">
                        <span class="font-bold text-gray-900">@mockRestaurants.Length</span> kết quả
                    </div>
                </div>

                <!-- Restaurant Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                    @{ var restaurantId = 1; }
                    @foreach (var restaurant in mockRestaurants)
                    {
                        var currentId = restaurantId++;
                        <div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 cursor-pointer hover:-translate-y-1">
                            <div class="relative">
                                <img src="@restaurant.Image" alt="@restaurant.Name" class="w-full h-48 object-cover" />
                                @if (!string.IsNullOrEmpty(restaurant.Badge))
                                {
                                    <div class="absolute top-2 left-2 bg-red-600 text-white px-2 py-1 rounded-md font-bold text-xs">
                                        @restaurant.Badge
                                    </div>
                                }
                                <div class="absolute bottom-2 right-2 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-md flex items-center gap-1">
                                    <span class="material-symbols-outlined text-gray-700 text-sm">schedule</span>
                                    <span class="text-xs font-semibold text-gray-700">25-35'</span>
                                </div>
                            </div>
                            <div class="p-4">
                                <h3 class="font-semibold text-gray-900 mb-2 truncate">@restaurant.Name</h3>
                                <div class="flex items-center gap-2 text-sm text-gray-600 mb-3">
                                    <div class="flex items-center gap-1">
                                        <span class="material-symbols-outlined text-yellow-500 text-base" style="font-variation-settings: 'FILL' 1;">star</span>
                                        <span class="font-semibold text-gray-900">@restaurant.Rating</span>
                                        <span>(@restaurant.Reviews)</span>
                                    </div>
                                    <span>•</span>
                                    <span>@restaurant.Distance</span>
                                </div>
                                <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                                    <span class="text-orange-600 font-bold text-base">Từ @restaurant.Price</span>
                                    <a href="@Url.Action("Details", "Restaurants", new { id = currentId })" class="px-4 py-2 rounded-md bg-orange-600 text-white text-sm font-medium hover:bg-orange-700 transition-colors">
                                        Mua ngay
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                <div class="mt-8 flex justify-center items-center gap-2">
                    <button class="w-9 h-9 rounded-md border border-gray-300 flex items-center justify-center hover:bg-gray-50 transition-colors">
                        <span class="material-symbols-outlined text-gray-600">chevron_left</span>
                    </button>
                    <button class="w-9 h-9 rounded-md bg-orange-600 text-white font-semibold flex items-center justify-center">1</button>
                    <button class="w-9 h-9 rounded-md border border-gray-300 flex items-center justify-center hover:bg-gray-50 transition-colors text-gray-700">2</button>
                    <button class="w-9 h-9 rounded-md border border-gray-300 flex items-center justify-center hover:bg-gray-50 transition-colors text-gray-700">3</button>
                    <span class="text-gray-500">...</span>
                    <button class="w-9 h-9 rounded-md border border-gray-300 flex items-center justify-center hover:bg-gray-50 transition-colors text-gray-700">12</button>
                    <button class="w-9 h-9 rounded-md border border-gray-300 flex items-center justify-center hover:bg-gray-50 transition-colors">
                        <span class="material-symbols-outlined text-gray-600">chevron_right</span>
                    </button>
                </div>
            </main>
        </div>
    </div>
</div>
