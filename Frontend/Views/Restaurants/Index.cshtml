@model IEnumerable<_225DAPM32.Models.Restaurant>

@{
    ViewData["Title"] = "Danh Sách Nhà Hàng";
}

<!-- Page Header -->
<div class="page-header bg-info text-white py-5 mb-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-4 fw-bold mb-2">
                    <i class="fas fa-store me-3"></i>Nhà Hàng Đối Tác
                </h1>
                <p class="lead mb-0">Khám phá các nhà hàng uy tín với món ăn ngon</p>
            </div>
            <div class="col-md-4 text-end">
                <div class="stats">
                    <div class="stat-item">
                        <span class="stat-number">@Model.Count()</span>
                        <span class="stat-label">Nhà Hàng</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <!-- Search and Filters -->
    <div class="filters-section mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control" placeholder="Tìm kiếm nhà hàng..." id="restaurantSearch">
                </div>
            </div>
            <div class="col-md-4">
                <select class="form-select" id="locationFilter">
                    <option value="">Tất cả khu vực</option>
                    <option value="quan1">Quận 1</option>
                    <option value="quan2">Quận 2</option>
                    <option value="quan3">Quận 3</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-primary w-100" id="searchBtn">
                    <i class="fas fa-filter me-1"></i>Tìm
                </button>
            </div>
        </div>
    </div>

    <!-- Restaurants Grid -->
    <div class="row g-4" id="restaurantsGrid">
        @foreach (var restaurant in Model)
        {
            <div class="col-lg-6 col-xl-4 restaurant-item">
                <div class="card restaurant-card h-100 border-0 shadow-sm">
                    <div class="card-img-container">
                        <img src="@restaurant.Image" class="card-img-top" alt="@restaurant.Name_Restaurant">
                        <div class="card-overlay">
                            <div class="overlay-content">
                                <button class="btn btn-light btn-sm mb-2">
                                    <i class="fas fa-heart me-1"></i>Yêu thích
                                </button>
                                <button class="btn btn-primary btn-sm" onclick="window.location.href='@Url.Action("Menu", "Restaurants", new { id = restaurant.Id_Restaurant })'">
                                    <i class="fas fa-eye me-1"></i>Xem menu
                                </button>
                            </div>
                        </div>
                        <div class="status-badge">
                            <i class="fas fa-circle text-success me-1"></i>Mở cửa
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold mb-2">@restaurant.Name_Restaurant</h5>
                        <p class="card-text text-muted flex-grow-1 mb-3">@restaurant.Description</p>

                        <div class="restaurant-info mb-3">
                            <div class="info-item mb-2">
                                <i class="fas fa-map-marker-alt text-danger me-2"></i>
                                <span class="small">@restaurant.Address</span>
                            </div>
                            <div class="info-item mb-2">
                                <i class="fas fa-clock text-warning me-2"></i>
                                <span class="small">@restaurant.OpenTime.ToString(@"hh\:mm") - @restaurant.CloseTime.ToString(@"hh\:mm")</span>
                            </div>
                            <div class="info-item">
                                <i class="fas fa-star text-warning me-2"></i>
                                <span class="small">4.5 (120 đánh giá)</span>
                            </div>
                        </div>

                        <div class="restaurant-stats mb-3">
                            <div class="row text-center">
                                <div class="col-4">
                                    <div class="stat">
                                        <span class="stat-number">25</span>
                                        <span class="stat-label small">Món ăn</span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="stat">
                                        <span class="stat-number">30</span>
                                        <span class="stat-label small">Phút</span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="stat">
                                        <span class="stat-number">4.2</span>
                                        <span class="stat-label small">Sao</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card-actions">
                            <a href="@Url.Action("Details", "Restaurants", new { id = restaurant.Id_Restaurant })" class="btn btn-primary flex-fill me-2">
                                <i class="fas fa-info-circle me-1"></i>Chi tiết
                            </a>
                            <button class="btn btn-success flex-fill" onclick="window.location.href='@Url.Action("Menu", "Restaurants", new { id = restaurant.Id_Restaurant })'">
                                <i class="fas fa-utensils me-1"></i>Xem menu
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-store fa-4x text-muted mb-3"></i>
            <h3 class="text-muted">Không tìm thấy nhà hàng nào</h3>
            <p class="text-muted">Hãy thử tìm kiếm với từ khóa khác</p>
        </div>
    }
</div>