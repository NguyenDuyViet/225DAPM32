@model _225DAPM32.Models.Food
@{
    string imageUrl(string? image) => string.IsNullOrWhiteSpace(image)
        ? "/images/placeholder-food.svg"
        : (image.StartsWith("http", StringComparison.OrdinalIgnoreCase) || image.StartsWith("/") ? image : "/" + image);
    var foodReviews = ViewBag.FoodReviews as Dictionary<int, List<_225DAPM32.Models.FoodReview>> ?? new();
    var reviews = foodReviews.GetValueOrDefault(Model.IdFood) ?? new List<_225DAPM32.Models.FoodReview>();
    var rating = reviews.Any() ? reviews.Average(review => review.Rating) : (double?)null;
    var modalId = $"foodDetail{Model.IdFood}";
}

<div class="bg-white p-3 rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-50 flex gap-4 group">
    <div class="w-24 h-24 flex-shrink-0 rounded-lg overflow-hidden relative">
        <img alt="@Model.Name" class="w-full h-full object-cover" src="@imageUrl(Model.Image)" onerror="this.onerror=null;this.src='/images/placeholder-food.svg';" />
        @if (Model.Discount.HasValue && Model.Discount > 0)
        {
            <div class="absolute top-1 left-1 bg-red-600 text-white text-[10px] font-bold px-1.5 py-0.5 rounded">
                -@Model.Discount.Value.ToString("N0")đ
            </div>
        }
    </div>
    <div class="flex flex-col justify-between flex-1">
        <div>
            <h3 class="text-base font-semibold text-gray-800 line-clamp-1">@Model.Name</h3>
            <p class="text-sm text-gray-500 line-clamp-2 mt-1">@Model.Description</p>
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1 text-xs text-gray-500">
                <span class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-yellow-500 text-[15px]">star</span>
                    <span>@(rating?.ToString("0.0") ?? "Chưa có đánh giá")</span>
                    @if (reviews.Any())
                    {
                        <span>(@reviews.Count)</span>
                    }
                </span>
                <span class="flex items-center gap-1 text-orange-600">
                    <span class="material-symbols-outlined text-[15px]">local_fire_department</span>
                    Đã bán @Model.SoldQuantity
                </span>
            </div>
        </div>
        <div class="flex items-center justify-between mt-2">
            <div class="flex flex-col">
                @if (Model.Discount.HasValue && Model.Discount > 0)
                {
                    <span class="font-bold text-orange-600 text-base">@((Model.Price - Model.Discount.Value).ToString("N0"))đ</span>
                    <span class="text-gray-400 line-through text-[12px]">@Model.Price.ToString("N0")đ</span>
                }
                else
                {
                    <span class="font-bold text-orange-600 text-base">@Model.Price.ToString("N0")đ</span>
                }
            </div>
            <div class="flex items-center gap-2">
                <button type="button" data-bs-toggle="modal" data-bs-target="#@modalId"
                        class="px-2 py-1 rounded border border-orange-200 text-orange-600 text-xs font-medium hover:bg-orange-50">
                    Xem chi tiết
                </button>
                @if (Model.PrepTime.HasValue)
                {
                    <span class="text-xs text-gray-400 flex items-center gap-1">
                        <span class="material-symbols-outlined text-[14px]">schedule</span>
                        @Model.PrepTime'
                    </span>
                }
                @if (Model.DailyQuantity > 0)
                {
                    <form asp-area="" asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="foodId" value="@Model.IdFood" />
                        <input type="hidden" name="quantity" value="1" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <button type="submit" title="Thêm vào giỏ hàng" class="w-8 h-8 rounded-full bg-orange-600 text-white flex items-center justify-center active:scale-90 transition-transform shadow-sm hover:bg-orange-700">
                            <span class="material-symbols-outlined text-[20px]">add</span>
                        </button>
                    </form>
                }
                else
                {
                    <span class="px-2 py-1 rounded bg-gray-100 text-gray-500 text-xs font-medium">Hết món</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@(modalId)Label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4 overflow-hidden">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="@(modalId)Label">@Model.Name</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
                    <div class="col-md-5">
                        <img src="@imageUrl(Model.Image)" alt="@Model.Name" class="w-100 rounded-3 object-fit-cover" style="height: 210px;" />
                        <p class="mt-3 text-muted">@Model.Description</p>
                    </div>
                    <div class="col-md-7">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="material-symbols-outlined text-warning">star</span>
                            <strong>@(rating?.ToString("0.0") ?? "Chưa có đánh giá")</strong>
                            <span class="text-muted">(@reviews.Count đánh giá)</span>
                        </div>
                        <p class="text-muted small mb-3"><i class="fas fa-fire text-warning me-1"></i>Đã bán @Model.SoldQuantity phần</p>
                        @if (!reviews.Any())
                        {
                            <p class="text-muted">Chưa có nhận xét cho món ăn này.</p>
                        }
                        else
                        {
                            <div class="vstack gap-3">
                                @foreach (var review in reviews.OrderByDescending(item => item.CreatedAt).Take(5))
                                {
                                    <div class="border rounded-3 p-3">
                                        <div class="d-flex justify-content-between mb-1">
                                            <strong>@review.Username</strong>
                                            <span class="text-warning"><i class="fas fa-star"></i> @review.Rating.ToString("0.0")</span>
                                        </div>
                                        <p class="small text-muted mb-0">@(string.IsNullOrWhiteSpace(review.Comment) ? "Khách hàng đã chấm điểm món ăn." : review.Comment)</p>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
