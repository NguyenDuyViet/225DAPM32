@inject _225DAPM32.Services.ApiClient ApiClient
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower();
    var token = Context.Session.GetString("Token");
    var role = Context.Session.GetString("Role");
    var username = Context.Session.GetString("Username");
    var isLoggedIn = !string.IsNullOrWhiteSpace(token);
    var cartCount = 0;

    if (isLoggedIn)
    {
        try
        {
            var cart = await ApiClient.GetResultAsync<_225DAPM32.Models.CartResponse>("Cart");
            cartCount = cart?.TotalQuantity ?? 0;
        }
        catch
        {
            cartCount = 0;
        }
    }
}

<header>
    <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 h-[80px] flex items-center justify-between gap-8">
            <a class="flex items-center flex-shrink-0" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="/LoGo_MNTN.png" alt="Logo" class="h-12" />
            </a>

            <form class="flex-grow max-w-xl" asp-area="" asp-controller="Restaurants" asp-action="Index" method="get">
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">search</span>
                    <input name="q" type="text" value="@Context.Request.Query["q"]" placeholder="Tìm kiếm món ăn, nhà hàng..." class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent text-sm" />
                </div>
            </form>

            <div class="flex items-center gap-6 flex-shrink-0">
                <a class="text-gray-700 font-medium hover:text-orange-600 transition-colors @(currentController == "home" ? "text-orange-600" : "")" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a class="text-gray-700 font-medium hover:text-orange-600 transition-colors @(currentController == "restaurants" ? "text-orange-600" : "")" asp-area="" asp-controller="Restaurants" asp-action="Index">Nhà hàng</a>
                <a class="text-gray-700 font-medium hover:text-orange-600 transition-colors relative @(currentController == "cart" ? "text-orange-600" : "")" asp-area="" asp-controller="Cart" asp-action="Index">
                    <span class="material-symbols-outlined">shopping_cart</span>
                    <span class="absolute -top-1 -right-1 bg-red-600 text-white text-[10px] rounded-full min-w-[18px] h-[18px] px-1 flex items-center justify-center font-bold" id="cartBadge">@cartCount</span>
                </a>

                @if (isLoggedIn)
                {
                    <div class="dropdown">
                        <button class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-lg font-medium transition-colors dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            @(string.IsNullOrWhiteSpace(username) ? "Tài khoản" : username)
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @if (role == "admin")
                            {
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Admin" asp-action="Index">Trang admin</a></li>
                            }
                            @if (role == "restaurant")
                            {
                                <li><a class="dropdown-item" asp-area="Restaurant" asp-controller="Restaurant" asp-action="Index">Trang nhà hàng</a></li>
                            }
                            <li><a class="dropdown-item" asp-area="" asp-controller="Profile" asp-action="Index">Trang cá nhân</a></li>
                            <li><a class="dropdown-item" asp-area="" asp-controller="Profile" asp-action="Orders">Đơn hàng</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                                    <button class="dropdown-item text-danger" type="submit">Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <button type="button" class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" data-bs-toggle="modal" data-bs-target="#authModal">
                        Đăng nhập
                    </button>
                }
            </div>
        </div>
    </nav>
</header>

<div class="modal fade" id="authModal" tabindex="-1" aria-labelledby="authModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title" id="authModalLabel">Đăng nhập hoặc đăng ký</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs mb-4" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#loginPane" type="button">Đăng nhập</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#registerPane" type="button">Đăng ký</button>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="loginPane" role="tabpanel">
                        <form asp-area="" asp-controller="Auth" asp-action="Login" method="post">
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <div class="mb-3">
                                <label class="form-label">Tên đăng nhập</label>
                                <input type="text" name="username" class="form-control" placeholder="Tên đăng nhập" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Mật khẩu</label>
                                <input type="password" name="password" class="form-control" placeholder="Mật khẩu" required />
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
                        </form>
                    </div>

                    <div class="tab-pane fade" id="registerPane" role="tabpanel">
                        <form asp-area="" asp-controller="Auth" asp-action="Register" method="post">
                            <div class="mb-3">
                                <label class="form-label">Họ và tên</label>
                                <input type="text" name="fullName" class="form-control" placeholder="Họ tên" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Tên đăng nhập</label>
                                <input type="text" name="username" class="form-control" placeholder="Tên đăng nhập" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" name="email" class="form-control" placeholder="Email" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Số điện thoại</label>
                                <input type="text" name="phone" class="form-control" placeholder="Số điện thoại" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Mật khẩu</label>
                                <input type="password" name="password" class="form-control" placeholder="Mật khẩu" required />
                            </div>
                            <button type="submit" class="btn btn-success w-100">Đăng ký</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
