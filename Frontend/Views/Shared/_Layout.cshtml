<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script type="importmap"></script>
    <link rel="icon" href="@Url.Content("~/LoGo_MNTN.png")" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_225DAPM32.styles.css" asp-append-version="true" />
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            vertical-align: middle;
        }
        .chat-new-dot {
            display: inline-block;
            width: 9px;
            height: 9px;
            margin-left: 6px;
            border-radius: 999px;
            background: #ef4444;
            box-shadow: 0 0 0 2px #fff;
            vertical-align: middle;
        }
    </style>
</head>
<body>
    <partial name="_Header" />

    @{
        var isRestaurantPage = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower() == "restaurants";
    }

    @if (TempData["Success"] is string success)
    {
        <div class="container mt-3">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @success
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="container mt-3">
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @error
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (isRestaurantPage)
    {
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <partial name="_Footer" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function refreshCustomerChatDot() {
            if (window.customerChatPageOwnsUnread) return;
            const dots = document.querySelectorAll('.js-customer-chat-dot');
            if (dots.length === 0) return;

            fetch('@Url.Action("ChatUnread", "Profile", new { area = "" })')
                .then(response => response.ok ? response.json() : { count: 0 })
                .then(data => dots.forEach(dot => dot.classList.toggle('d-none', Number(data.count || 0) === 0)))
                .catch(() => {});

            window.setTimeout(refreshCustomerChatDot, 15000);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
