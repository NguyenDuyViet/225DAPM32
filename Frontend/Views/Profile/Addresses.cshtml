@{
    var user = ViewBag.User as _225DAPM32.Models.User;
    var addresses = ViewBag.Addresses as List<_225DAPM32.Models.Address>;
}

<div class="container">
    <div class="row">
        <!-- Profile Navigation -->
        <div class="col-md-3">
            <div class="profile-nav p-3">
                <h5 class="mb-3">Tài khoản</h5>
                <nav class="nav flex-column">
                    <a class="nav-link" href="@Url.Action("Index", "Profile")">
                        <i class="fas fa-tachometer-alt me-2"></i>Tổng quan
                    </a>
                    <a class="nav-link" href="@Url.Action("Orders", "Profile")">
                        <i class="fas fa-shopping-bag me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link active" href="@Url.Action("Addresses", "Profile")">
                        <i class="fas fa-map-marker-alt me-2"></i>Địa chỉ
                    </a>
                    <a class="nav-link" href="@Url.Action("Settings", "Profile")">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                    <hr class="my-3">
                    <a class="nav-link text-danger" href="#" onclick="logout()">
                        <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                    </a>
                </nav>
            </div>
        </div>

        <!-- Addresses Content -->
        <div class="col-md-9">
            <div class="profile-content">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2>Địa chỉ giao hàng</h2>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addAddressModal">
                        <i class="fas fa-plus me-2"></i>Thêm địa chỉ mới
                    </button>
                </div>

                @if (addresses.Any())
                {
                    <div class="row">
                        @foreach (var address in addresses)
                        {
                            <div class="col-md-6 mb-4">
                                <div class="card address-card @(address.Is_Default ? "border-primary" : "")">
                                    <div class="card-body">
                                        @if (address.Is_Default)
                                        {
                                            <div class="default-badge">
                                                <span class="badge bg-primary">Mặc định</span>
                                            </div>
                                        }
                                        <h5 class="card-title">@address.Name</h5>
                                        <p class="card-text mb-1">
                                            <i class="fas fa-phone me-2"></i>@address.Phone
                                        </p>
                                        <p class="card-text">
                                            <i class="fas fa-map-marker-alt me-2"></i>@address.AddressDetail
                                        </p>
                                        @if (!string.IsNullOrEmpty(address.Note))
                                        {
                                            <p class="card-text text-muted small">
                                                <i class="fas fa-sticky-note me-2"></i>@address.Note
                                            </p>
                                        }
                                        <div class="card-actions mt-3">
                                            <button class="btn btn-outline-primary btn-sm me-2" onclick="editAddress(@address.Id_Address)">
                                                <i class="fas fa-edit me-1"></i>Sửa
                                            </button>
                                            @if (!address.Is_Default)
                                            {
                                                <button class="btn btn-outline-success btn-sm me-2" onclick="setDefault(@address.Id_Address)">
                                                    <i class="fas fa-star me-1"></i>Đặt mặc định
                                                </button>
                                            }
                                            <button class="btn btn-outline-danger btn-sm" onclick="deleteAddress(@address.Id_Address)">
                                                <i class="fas fa-trash me-1"></i>Xóa
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-map-marker-alt fa-4x text-muted mb-3"></i>
                        <h4 class="text-muted">Chưa có địa chỉ nào</h4>
                        <p class="text-muted">Thêm địa chỉ giao hàng để đặt món dễ dàng hơn!</p>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addAddressModal">
                            <i class="fas fa-plus me-2"></i>Thêm địa chỉ đầu tiên
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Add Address Modal -->
<div class="modal fade" id="addAddressModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thêm địa chỉ mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addressForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="addressName" class="form-label">Họ tên</label>
                            <input type="text" class="form-control" id="addressName" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="addressPhone" class="form-label">Số điện thoại</label>
                            <input type="tel" class="form-control" id="addressPhone" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="addressText" class="form-label">Địa chỉ</label>
                        <textarea class="form-control" id="addressText" rows="3" placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="addressNote" class="form-label">Ghi chú (tùy chọn)</label>
                        <input type="text" class="form-control" id="addressNote" placeholder="Ví dụ: Gần trường học, công ty ABC...">
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="isDefault">
                        <label class="form-check-label" for="isDefault">
                            Đặt làm địa chỉ mặc định
                        </label>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="saveAddress()">Lưu địa chỉ</button>
            </div>
        </div>
    </div>
</div>

<script>
function editAddress(id) {
    alert('Chỉnh sửa địa chỉ #' + id);
}

function setDefault(id) {
    alert('Đặt địa chỉ #' + id + ' làm mặc định');
}

function deleteAddress(id) {
    if (confirm('Bạn có chắc muốn xóa địa chỉ này?')) {
        alert('Đã xóa địa chỉ #' + id);
    }
}

function saveAddress() {
    // Validate form
    const name = document.getElementById('addressName').value;
    const phone = document.getElementById('addressPhone').value;
    const address = document.getElementById('addressText').value;

    if (!name || !phone || !address) {
        alert('Vui lòng điền đầy đủ thông tin!');
        return;
    }

    alert('Đã lưu địa chỉ mới!');
    // Close modal
    const modal = bootstrap.Modal.getInstance(document.getElementById('addAddressModal'));
    modal.hide();
    // Reset form
    document.getElementById('addressForm').reset();
}

function updateAccountButton() {
    const loggedIn = localStorage.getItem('mgtn_loggedIn') === 'true';
    const accountIcon = document.getElementById('accountIcon');
    const accountButton = document.getElementById('accountButton');
    if (!accountIcon || !accountButton) return;
    accountIcon.className = loggedIn ? 'fas fa-user' : 'fas fa-user-plus';
    accountButton.title = loggedIn ? 'Trang cá nhân' : 'Đăng nhập / Đăng ký';
}

function logout() {
    if (confirm('Bạn có chắc chắn muốn đăng xuất?')) {
        // Clear user session/localStorage
        localStorage.removeItem('mgtn_loggedIn');

        // Update UI immediately
        updateAccountButton();

        // Redirect to home page
        window.location.href = '@Url.Action("Index", "Home")';
    }
}
</script>