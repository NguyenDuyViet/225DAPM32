@{
    var user = ViewBag.User as _225DAPM32.Models.User ?? new _225DAPM32.Models.User
    {
        Username = Context.Session.GetString("Username") ?? "",
        FullName = Context.Session.GetString("Username") ?? "",
        Phone = "",
        Address = ""
    };
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-3">
            <div class="profile-nav p-3">
                <h5 class="mb-3">Tài khoản</h5>
                <nav class="nav flex-column">
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Index">
                        <i class="fas fa-tachometer-alt me-2"></i>Tổng quan
                    </a>
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Orders">
                        <i class="fas fa-shopping-bag me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link active" asp-area="" asp-controller="Profile" asp-action="Addresses">
                        <i class="fas fa-map-marker-alt me-2"></i>Địa chỉ
                    </a>
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Settings">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                </nav>
            </div>
        </div>

        <div class="col-md-9">
            <div class="profile-content">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2>Địa chỉ giao hàng</h2>
                    <a asp-area="" asp-controller="Profile" asp-action="Settings" class="btn btn-primary">
                        <i class="fas fa-edit me-2"></i>Cập nhật vị trí
                    </a>
                </div>

                @if (!string.IsNullOrWhiteSpace(user.Address))
                {
                    <div class="card address-card border-primary">
                        <div class="card-body">
                            <span class="badge bg-primary mb-3">Mặc định</span>
                            <h5 class="card-title">@(!string.IsNullOrWhiteSpace(user.FullName) ? user.FullName : user.Username)</h5>
                            <p class="card-text mb-1">
                                <i class="fas fa-phone me-2"></i>@user.Phone
                            </p>
                            <p class="card-text mb-0">
                                <i class="fas fa-map-marker-alt me-2"></i>@user.Address
                            </p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-map-marker-alt fa-4x text-muted mb-3"></i>
                        <h4 class="text-muted">Bạn chưa cập nhật vị trí</h4>
                        <p class="text-muted">Vui lòng vào cài đặt để cập nhật địa chỉ giao hàng trước khi đặt món.</p>
                        <a asp-area="" asp-controller="Profile" asp-action="Settings" class="btn btn-primary">
                            Cập nhật vị trí ngay
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
