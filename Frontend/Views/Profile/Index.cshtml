@{
    var user = ViewBag.User as _225DAPM32.Models.User ?? new _225DAPM32.Models.User
    {
        Username = Context.Session.GetString("Username") ?? "Khách hàng",
        FullName = Context.Session.GetString("Username") ?? "Khách hàng",
        Avatar = "/images/placeholder-profile.svg",
        Status = "active",
        UpdateBio = "Chào mừng bạn đến với Món Ngon Tại Nhà.",
        CancelRate = 0
    };
    var orders = ViewBag.Orders as List<_225DAPM32.Models.Order> ?? new List<_225DAPM32.Models.Order>();
    var addresses = ViewBag.Addresses as List<_225DAPM32.Models.Address> ?? new List<_225DAPM32.Models.Address>();
    var avatar = string.IsNullOrWhiteSpace(user.Avatar) ? "/images/placeholder-profile.svg" : user.Avatar;
}

<div class="profile-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-3 text-center">
                <img src="@avatar" alt="Avatar" class="profile-avatar mb-3" onerror="this.onerror=null;this.src='/images/placeholder-profile.svg';">
            </div>
            <div class="col-md-9">
                <h1 class="display-4 fw-bold mb-2">@(!string.IsNullOrWhiteSpace(user.FullName) ? user.FullName : user.Username)</h1>
                <p class="lead mb-3">@user.UpdateBio</p>
                <div class="row">
                    <div class="col-md-3">
                        <div class="text-center">
                            <h3 class="text-white">@orders.Count</h3>
                            <small>Đơn hàng</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-center">
                            <h3 class="text-white">@addresses.Count</h3>
                            <small>Địa chỉ</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-center">
                            <h3 class="text-white">@(user.CancelRate * 100)%</h3>
                            <small>Tỷ lệ hủy</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-center">
                            <h3 class="text-white">@user.Status</h3>
                            <small>Trạng thái</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-md-3">
            <div class="profile-nav p-3">
                <h5 class="mb-3">Tài khoản</h5>
                <nav class="nav flex-column">
                    <a class="nav-link active" asp-area="" asp-controller="Profile" asp-action="Index">
                        <i class="fas fa-tachometer-alt me-2"></i>Tổng quan
                    </a>
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Orders">
                        <i class="fas fa-shopping-bag me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Chat">
                        <i class="fas fa-comments me-2"></i>Chat nhà hàng <span class="chat-new-dot js-customer-chat-dot d-none" title="Có tin nhắn mới"></span>
                    </a>
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Addresses">
                        <i class="fas fa-map-marker-alt me-2"></i>Địa chỉ
                    </a>
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Settings">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                    <hr class="my-3">
                    <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit" class="nav-link text-danger border-0 bg-transparent p-0">
                            <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                        </button>
                    </form>
                </nav>
            </div>
        </div>

        <div class="col-md-9">
            <div class="profile-content">
                <div class="mb-4">
                    <h4 class="mb-3">
                        <i class="fas fa-clock me-2"></i>Đơn hàng gần đây
                    </h4>
                    @if (!orders.Any())
                    {
                        <div class="alert alert-light border">Bạn chưa có đơn hàng nào.</div>
                    }
                    else
                    {
                        <div class="row">
                            @foreach (var order in orders.Take(3))
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h6 class="card-title mb-0">#@(!string.IsNullOrWhiteSpace(order.OrderCode) ? order.OrderCode : order.IdOrder.ToString())</h6>
                                                <span class="badge bg-@order.StatusColor">@order.StatusText</span>
                                            </div>
                                            <p class="card-text small text-muted mb-2">
                                                @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                            </p>
                                            <p class="card-text fw-bold text-primary mb-0">
                                                @order.Total.ToString("N0") VND
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <a asp-area="" asp-controller="Profile" asp-action="Orders" class="btn btn-outline-primary">
                        Xem tất cả đơn hàng
                    </a>
                </div>

                <div class="mb-4">
                    <h4 class="mb-3">
                        <i class="fas fa-map-marker-alt me-2"></i>Địa chỉ đã lưu
                    </h4>
                    @if (!addresses.Any())
                    {
                        <div class="alert alert-light border">Bạn chưa lưu địa chỉ nào.</div>
                    }
                    else
                    {
                        <div class="row">
                            @foreach (var address in addresses)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h6 class="card-title mb-0">@address.Name</h6>
                                                @if (address.IsDefault)
                                                {
                                                    <span class="badge bg-primary">Mặc định</span>
                                                }
                                            </div>
                                            <p class="card-text small mb-1">@address.Phone</p>
                                            <p class="card-text">@address.AddressDetail</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <a asp-area="" asp-controller="Profile" asp-action="Addresses" class="btn btn-outline-primary">
                        Quản lý địa chỉ
                    </a>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="fas fa-calendar-alt fa-2x text-primary mb-2"></i>
                                <h5>Thành viên từ</h5>
                                <p class="text-muted">@user.CreatedAt.ToString("MM/yyyy")</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="fas fa-clock fa-2x text-success mb-2"></i>
                                <h5>Lần cuối online</h5>
                                <p class="text-muted">@(user.LastOnline?.ToString("dd/MM/yyyy") ?? "Chưa có dữ liệu")</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="fas fa-star fa-2x text-warning mb-2"></i>
                                <h5>Đánh giá</h5>
                                <p class="text-muted">4.8/5.0</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
