@{
    var user = ViewBag.User as _225DAPM32.Models.User;
    var orders = ViewBag.Orders as List<_225DAPM32.Models.Order>;
}

<div class="container">
    <div class="row">
        <!-- Profile Navigation -->
        <div class="col-md-3">
            <div class="profile-nav p-3">
                <h5 class="mb-3">Tài khoản</h5>
                <nav class="nav flex-column">
                    <a class="nav-link" href="@Url.Action("Index", "Profile")">
                        <i class="fas fa-tachometer-alt me-2"></i>Tổng quan
                    </a>
                    <a class="nav-link active" href="@Url.Action("Orders", "Profile")">
                        <i class="fas fa-shopping-bag me-2"></i>Đơn hàng
                    </a>
                    <a class="nav-link" href="@Url.Action("Addresses", "Profile")">
                        <i class="fas fa-map-marker-alt me-2"></i>Địa chỉ
                    </a>
                    <a class="nav-link" href="@Url.Action("Settings", "Profile")">
                        <i class="fas fa-cog me-2"></i>Cài đặt
                    </a>
                    <hr class="my-3">
                    <a class="nav-link text-danger" href="#" onclick="logout()">
                        <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                    </a>
                </nav>
            </div>
        </div>

        <!-- Orders Content -->
        <div class="col-md-9">
            <div class="profile-content">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2>Đơn hàng của tôi</h2>
                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" name="statusFilter" id="all" autocomplete="off" checked>
                        <label class="btn btn-outline-primary" for="all">Tất cả</label>

                        <input type="radio" class="btn-check" name="statusFilter" id="pending" autocomplete="off">
                        <label class="btn btn-outline-warning" for="pending">Chờ xử lý</label>

                        <input type="radio" class="btn-check" name="statusFilter" id="delivering" autocomplete="off">
                        <label class="btn btn-outline-info" for="delivering">Đang giao</label>

                        <input type="radio" class="btn-check" name="statusFilter" id="completed" autocomplete="off">
                        <label class="btn btn-outline-success" for="completed">Hoàn thành</label>
                    </div>
                </div>

                @if (orders.Any())
                {
                    <div class="row">
                        @foreach (var order in orders)
                        {
                            <div class="col-12 mb-3">
                                <div class="card order-card">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-md-2">
                                                <h5 class="mb-0">#@order.Id_Order</h5>
                                                <small class="text-muted">@order.Created_At.ToString("dd/MM/yyyy")</small>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="order-items">
                                                    <small class="text-muted">2 món ăn</small>
                                                    <p class="mb-0">Phở Bò, Gà Rán</p>
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <span class="badge fs-6 bg-@(order.Status == "completed" ? "success" : order.Status == "delivering" ? "warning" : "secondary")">
                                                    @order.Status
                                                </span>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="order-total">
                                                    <strong class="text-primary">@order.Total.ToString("N0") VND</strong>
                                                    <small class="text-muted d-block">+ @order.ShippingFee.ToString("N0") VND phí ship</small>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="btn-group" role="group">
                                                    <button class="btn btn-outline-primary btn-sm" onclick="viewOrderDetails(@order.Id_Order)">
                                                        <i class="fas fa-eye me-1"></i>Chi tiết
                                                    </button>
                                                    @if (order.Status == "completed")
                                                    {
                                                        <button class="btn btn-outline-success btn-sm">
                                                            <i class="fas fa-star me-1"></i>Đánh giá
                                                        </button>
                                                    }
                                                    @if (order.Status == "pending" || order.Status == "confirmed")
                                                    {
                                                        <button class="btn btn-outline-danger btn-sm">
                                                            <i class="fas fa-times me-1"></i>Hủy đơn
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-shopping-bag fa-4x text-muted mb-3"></i>
                        <h4 class="text-muted">Chưa có đơn hàng nào</h4>
                        <p class="text-muted">Hãy đặt món ăn đầu tiên của bạn!</p>
                        <a href="@Url.Action("Index", "Foods")" class="btn btn-primary">
                            Đặt món ngay
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
function viewOrderDetails(orderId) {
    // Giả lập modal hoặc redirect
    alert('Xem chi tiết đơn hàng #' + orderId);
}

function updateAccountButton() {
    const loggedIn = localStorage.getItem('mgtn_loggedIn') === 'true';
    const accountIcon = document.getElementById('accountIcon');
    const accountButton = document.getElementById('accountButton');
    if (!accountIcon || !accountButton) return;
    accountIcon.className = loggedIn ? 'fas fa-user' : 'fas fa-user-plus';
    accountButton.title = loggedIn ? 'Trang cá nhân' : 'Đăng nhập / Đăng ký';
}

function logout() {
    if (confirm('Bạn có chắc chắn muốn đăng xuất?')) {
        // Clear user session/localStorage
        localStorage.removeItem('mgtn_loggedIn');

        // Update UI immediately
        updateAccountButton();

        // Redirect to home page
        window.location.href = '@Url.Action("Index", "Home")';
    }
}
</script>