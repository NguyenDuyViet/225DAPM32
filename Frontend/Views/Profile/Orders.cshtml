@{
    var orders = ViewBag.Orders as List<_225DAPM32.Models.Order> ?? new();
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-3">
            <div class="profile-nav p-3">
                <h5 class="mb-3">Tài khoản</h5>
                <nav class="nav flex-column">
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Index"><i class="fas fa-user me-2"></i>Tổng quan</a>
                    <a class="nav-link active" asp-area="" asp-controller="Profile" asp-action="Orders"><i class="fas fa-shopping-bag me-2"></i>Đơn hàng</a>
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Addresses"><i class="fas fa-map-marker-alt me-2"></i>Địa chỉ</a>
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Settings"><i class="fas fa-cog me-2"></i>Cài đặt</a>
                </nav>
            </div>
        </div>

        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0">Đơn hàng của tôi</h2>
                <a asp-area="" asp-controller="Restaurants" asp-action="Index" class="btn btn-primary">Đặt món mới</a>
            </div>

            @if (!orders.Any())
            {
                <div class="text-center py-5 bg-light rounded">
                    <i class="fas fa-shopping-bag fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">Chưa có đơn hàng nào</h4>
                </div>
            }
            else
            {
                <div class="vstack gap-3">
                    @foreach (var order in orders.OrderByDescending(o => o.CreatedAt))
                    {
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                                    <div>
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <h5 class="fw-bold mb-0">@(string.IsNullOrWhiteSpace(order.OrderCode) ? $"#{order.IdOrder}" : order.OrderCode)</h5>
                                            <span class="badge bg-@order.StatusColor">@order.StatusText</span>
                                        </div>
                                        <p class="text-muted mb-1">@order.RestaurantName</p>
                                        <p class="text-muted small mb-2">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                                        <div class="small">
                                            @foreach (var item in order.Items)
                                            {
                                                <div>@item.Quantity x @item.FoodName</div>
                                            }
                                        </div>
                                    </div>
                                    <div class="text-lg-end">
                                        <div class="text-muted small">Tổng thanh toán</div>
                                        <div class="fs-4 fw-bold text-success">@order.FinalTotal.ToString("N0")đ</div>
                                        <div class="text-muted small mt-2">@order.DeliveryAddress</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
