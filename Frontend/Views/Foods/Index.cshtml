@model IEnumerable<_225DAPM32.Models.Food>
@{
    ViewData["Title"] = "Danh sách món ăn";
    var categories = ViewBag.Categories as List<_225DAPM32.Models.Category> ?? new();
    int? selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    string imageUrl(string? image) => string.IsNullOrWhiteSpace(image)
        ? "/images/placeholder-food.svg"
        : (image.StartsWith("http", StringComparison.OrdinalIgnoreCase) || image.StartsWith("/") ? image : "/" + image);
}

<div class="py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-end mb-4">
        <div>
            <h1 class="fw-bold mb-2">Món ăn</h1>
            <p class="text-muted mb-0">Dữ liệu được lấy trực tiếp từ danh mục và thực đơn trong hệ thống.</p>
        </div>
        <form method="get" class="d-flex gap-2">
            <select class="form-select" name="categoryId" onchange="this.form.submit()">
                <option value="">Tất cả danh mục</option>
                @foreach (var category in categories)
                {
                    <option value="@category.IdCategory" selected="@(selectedCategoryId == category.IdCategory)">
                        @category.Name @(category.FoodCount.HasValue ? $"({category.FoodCount})" : "")
                    </option>
                }
            </select>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded">
            <i class="fas fa-utensils fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">Chưa có món ăn</h4>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var food in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <a asp-area="" asp-controller="Foods" asp-action="Details" asp-route-id="@food.IdFood" class="text-decoration-none">
                            <img src="@imageUrl(food.Image)" class="card-img-top" alt="@food.Name" style="height: 220px; object-fit: cover;" onerror="this.onerror=null;this.src='/images/placeholder-food.svg';" />
                        </a>
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between gap-2 mb-2">
                                <h5 class="card-title fw-bold mb-0">@food.Name</h5>
                                @if (food.Discount > 0)
                                {
                                    <span class="badge bg-danger align-self-start">Giảm @food.Discount?.ToString("N0")đ</span>
                                }
                            </div>
                            <p class="text-muted small mb-2">@(!string.IsNullOrWhiteSpace(food.CategoryName) ? food.CategoryName : "Chưa phân loại")</p>
                            <p class="card-text text-muted flex-grow-1">@food.Description</p>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    @if (food.Discount > 0)
                                    {
                                        <div class="text-muted text-decoration-line-through small">@food.Price.ToString("N0")đ</div>
                                    }
                                    <div class="fw-bold text-orange-600">@food.FinalPrice.ToString("N0")đ</div>
                                </div>
                                <span class="text-muted small"><i class="fas fa-clock me-1"></i>@(food.PrepTime ?? 0) phút</span>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-area="" asp-controller="Foods" asp-action="Details" asp-route-id="@food.IdFood" class="btn btn-outline-primary flex-fill">Chi tiết</a>
                                <form asp-area="" asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-fill">
                                    <input type="hidden" name="foodId" value="@food.IdFood" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="fas fa-cart-plus me-1"></i>Thêm
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
