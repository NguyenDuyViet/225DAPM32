@model _225DAPM32.Models.Food
@{
    ViewData["Title"] = Model.Name;
    string imageUrl(string? image) => string.IsNullOrWhiteSpace(image)
        ? "/images/placeholder-food.svg"
        : (image.StartsWith("http", StringComparison.OrdinalIgnoreCase) || image.StartsWith("/") ? image : "/" + image);
}

<div class="py-5">
    <div class="row g-5">
        <div class="col-lg-6">
            <img src="@imageUrl(Model.Image)" class="img-fluid rounded shadow-sm w-100" style="max-height: 520px; object-fit: cover;" alt="@Model.Name" onerror="this.onerror=null;this.src='/images/placeholder-food.svg';" />
        </div>
        <div class="col-lg-6">
            <p class="text-muted mb-2">@(!string.IsNullOrWhiteSpace(Model.CategoryName) ? Model.CategoryName : "Món ăn")</p>
            <h1 class="fw-bold mb-3">@Model.Name</h1>
            <p class="lead text-muted">@Model.Description</p>
            <div class="d-flex gap-4 text-muted mb-4">
                <span><i class="fas fa-clock text-warning me-1"></i>@(Model.PrepTime ?? 0) phút</span>
                <span><i class="fas fa-fire text-danger me-1"></i>@(Model.CookCount ?? 0) lượt nấu</span>
            </div>
            <div class="mb-4">
                @if (Model.Discount > 0)
                {
                    <div class="text-muted text-decoration-line-through">@Model.Price.ToString("N0")đ</div>
                }
                <div class="display-6 fw-bold text-success">@Model.FinalPrice.ToString("N0")đ</div>
            </div>

            <form asp-area="" asp-controller="Cart" asp-action="AddToCart" method="post" class="p-4 bg-light rounded">
                <input type="hidden" name="foodId" value="@Model.IdFood" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                <div class="mb-3">
                    <label class="form-label">Số lượng</label>
                    <input type="number" name="quantity" class="form-control" value="1" min="1" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Ghi chú</label>
                    <textarea name="note" class="form-control" rows="3" placeholder="Ví dụ: ít cay, không hành..."></textarea>
                </div>
                <button type="submit" class="btn btn-success btn-lg w-100">Thêm vào giỏ hàng</button>
            </form>
        </div>
    </div>
</div>
